	method void LogCupSlotInfo(any slot)
		if slot == nil then
			return
		end
		
		local cupInfo = self:GetCupInfoFromSlot(slot)
		if cupInfo == nil then
			log("Clicked cup slot: " .. slot.id .. " / hasCup: false")
			return
		end
		
		-- 도현아 컵 데이터 받아라 cupinfo가 컵 데이터다 가져가라
		
		log("Clicked cup slot: " .. slot.id .. " / hasCup: true / " .. self:GetCupInfoText(cupInfo))
	end

