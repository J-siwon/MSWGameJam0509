	property ButtonComponent slotCup4 = "c3ca0001-cafe-cafe-cafe-c3cafe000018"
	property ButtonComponent slotCup5 = "c3ca0001-cafe-cafe-cafe-c3cafe000019"
	property ButtonComponent slotIng1 = "c3ca0001-cafe-cafe-cafe-c3cafe000020"
	property ButtonComponent slotIng2 = "c3ca0001-cafe-cafe-cafe-c3cafe000021"
	property ButtonComponent slotMixer1 = "c3ca0001-cafe-cafe-cafe-c3cafe000022"
	property ButtonComponent slotMixer2 = "c3ca0001-cafe-cafe-cafe-c3cafe000023"
	property ButtonComponent slotMixer3 = "c3ca0001-cafe-cafe-cafe-c3cafe000024"
	-- 선택된 대상에 따라 오른쪽/아래쪽에서 나타나는 공용 액션 버튼
	property ButtonComponent btnPrepAction = "c3ca0001-cafe-cafe-cafe-c3cafe000025"
	property ButtonComponent btnBrewShotAction = "c3ca0001-cafe-cafe-cafe-c3cafe000026"
	property ButtonComponent btnMixAction = "c3ca0001-cafe-cafe-cafe-c3cafe000027"
	property ButtonComponent btnDiscardAction = "c3ca0001-cafe-cafe-cafe-c3cafe000028"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- ServiceManager는 데이터 생성, 선택 규칙, UI 버튼 연결을 조율하는 시작점이다.
		self.GameData = self:CreateInitialGameData()
		self.SelectionManager = self:CreateInitialSelectionManager()
		self.actionButtonConfigs = self:CreateActionButtonConfigs()
		self.actionButtonTweenIds = {}
		self.progressTimerIds = {}
		self:ConnectGameButtons()
		self:HideActionButtonsImmediately()
	end

	method any CreateInitialGameData()
		-- 분리된 데이터 팩토리가 로드되어 있으면 그쪽을 사용하고, 없으면 내부 구현으로 동작한다.
		if _DataFactory ~= nil then
			return _DataFactory:CreateGameData()
		end
		
		log("DataFactory is not loaded. Use ServiceManager fallback data factory.")
		return self:CreateGameData()
	end

	method any CreateInitialSelectionManager()
		-- 선택 매니저도 외부 스크립트를 우선 사용하고, 로드되지 않았을 때만 내부 구현으로 대체한다.
		if _SelectionManagerFactory ~= nil then
			return _SelectionManagerFactory:CreateSelectionManager(self)
		end
		
		log("SelectionManagerFactory is not loaded. Use ServiceManager fallback selection manager.")
		return self:CreateSelectionManager()
	end

	method any CreateGameData()
		-- DataFactory가 없을 때만 사용하는 예비 데이터 생성 로직이다.
		return {
			IngredientSlots = self:CreateIngredientSlots(),
			CupSlots = self:CreateCupSlots(),
			IngredientDefs = self:CreateIngredientDefs(),
			MixerRecipes = self:CreateMixerRecipes(),
			Mixers = self:CreateMixers(),
		}
	end

	method any CreateIngredientSlots()
		return {
			[1] = { id = "IngredientSlot_1", state = "EMPTY", ingredientId = nil },
			[2] = { id = "IngredientSlot_2", state = "EMPTY", ingredientId = nil },
		}
	end

	method any CreateCupSlots()
		return {
			[1] = { id = "CupSlot_1", isCoffeeMachine = true, coffeeShotId = "CoffeeShot_1", hasCup = false, cupData = nil },
			[2] = { id = "CupSlot_2", isCoffeeMachine = true, coffeeShotId = "CoffeeShot_2", hasCup = false, cupData = nil },
			[3] = { id = "CupSlot_3", isCoffeeMachine = true, coffeeShotId = "CoffeeShot_3", hasCup = false, cupData = nil },
			[4] = { id = "CupSlot_4", isCoffeeMachine = false, hasCup = false, cupData = nil },
			[5] = { id = "CupSlot_5", isCoffeeMachine = false, hasCup = false, cupData = nil },
		}
	end

