	method void RefreshCupSlotByCupData(any cupData)
		if cupData == nil or self.GameData == nil or self.GameData.CupSlots == nil then
			return
		end
		
		for i = 1, #self.GameData.CupSlots do
			local slot = self.GameData.CupSlots[i]
			if slot ~= nil and slot.cupData == cupData then
				self:RefreshCupSlotImage(slot)
				return
			end
		end
	end

	method void MoveOrSwapCupSlot(any fromSlot, any toSlot)
		-- 컵이 있는 슬롯을 선택한 상태에서 다른 컵 슬롯을 누르면 이동 또는 스왑한다.
		if fromSlot == nil or toSlot == nil then
			return
		end
		
		if fromSlot == toSlot then
			return
		end
		
		if fromSlot.isBrewingShot == true or toSlot.isBrewingShot == true then
			log("Cannot move or swap cup while brewing shot")
			return
		end
		
		if fromSlot.hasCup ~= true then
			return
		end
		
		local fromCupData = fromSlot.cupData
		local toCupData = toSlot.cupData
		local toHasCup = toSlot.hasCup
		
		toSlot.hasCup = true
		toSlot.cupData = fromCupData
		
		fromSlot.hasCup = toHasCup
		fromSlot.cupData = toCupData
		
		self:RefreshCupSlotImage(fromSlot)
		self:RefreshCupSlotImage(toSlot)
		
		if toHasCup == true then
			log("Swapped cups: " .. fromSlot.id .. " <-> " .. toSlot.id)
		else
			log("Moved cup: " .. fromSlot.id .. " -> " .. toSlot.id)
		end
	end

	method boolean IsPackageSlot(any slot)
		return slot ~= nil and (slot.isPackageSlot == true or slot.id == "CupSlot_4")
	end

	method boolean IsWaterSlot(any slot)
		return slot ~= nil and (slot.isWaterSlot == true or slot.id == "CupSlot_5")
	end

	method any GetPackageSlot()
		if self.GameData == nil or self.GameData.CupSlots == nil then
			return nil
		end

		return self.GameData.CupSlots[4]
	end

	method boolean PackageCupSlot(any fromSlot, any packageSlot)
		if fromSlot == nil or fromSlot.hasCup ~= true or fromSlot.cupData == nil then
			return false
		end

		local completedDrink = self:GetCompletedDrinkInfo(fromSlot.cupData)
		if completedDrink == nil or completedDrink.iconRUID == nil or completedDrink.iconRUID == "" then
			log("Cannot package cup. No completed drink recipe.")
			return false
		end

		local cupData = fromSlot.cupData
		cupData.isPackaged = true
		cupData.packagedDrinkId = completedDrink.id
		cupData.packagedDrinkImageRUID = completedDrink.iconRUID
		cupData.packagedDrinkImageWidth = completedDrink.imageWidth
		cupData.packagedDrinkImageHeight = completedDrink.imageHeight

		self:RefreshCupSlotImage(fromSlot)
		self:RefreshPackageButtonState()
		self:ClearOrderPreview()
		log("Packaged cup in place: " .. tostring(fromSlot.id))
		return true
	end

	method any GetFirstPackageableCupSlot()
		if self.GameData == nil or self.GameData.CupSlots == nil then
			return nil
		end

		for i = 1, #self.GameData.CupSlots do
			local slot = self.GameData.CupSlots[i]
			if slot ~= nil and self:IsPackageSlot(slot) == false and slot.hasCup == true and slot.cupData ~= nil and slot.cupData.isPackaged ~= true then
				if self:GetCompletedDrinkImageRUID(slot.cupData) ~= "" then
					return slot
				end
			end
		end

		return nil
	end

	method any GetFirstPackagedCupSlot()
		if self.GameData == nil or self.GameData.CupSlots == nil then
			return nil
		end

		for i = 1, #self.GameData.CupSlots do
			local slot = self.GameData.CupSlots[i]
			if slot ~= nil and slot.hasCup == true and slot.cupData ~= nil and slot.cupData.isPackaged == true then
				return slot
			end
		end

		return nil
	end

	method void InitializeCoffeeShotButtons()
		self:SetButtonEffectVisible(self.btnCoffeeShot1, false)
		self:SetButtonEffectVisible(self.btnCoffeeShot2, false)
		self:SetButtonEffectVisible(self.btnCoffeeShot3, false)
		self:RefreshCoffeeShotButtonStates()
	end

	method void RefreshCoffeeShotButtonStates()
		for index = 1, 3 do
			self:RefreshCoffeeShotButtonState(index)
		end
	end

	method void RefreshCoffeeShotButtonStateBySlot(any slot)
		local index = self:GetCoffeeShotIndexForSlot(slot)
		if index <= 0 then
			return
		end

		self:RefreshCoffeeShotButtonState(index)
	end

	method number GetCoffeeShotIndexForSlot(any slot)
		if slot == nil then
			return 0
		end

		if slot.id == "CupSlot_1" then
			return 1
		end
		if slot.id == "CupSlot_2" then
			return 2
		end
		if slot.id == "CupSlot_3" then
			return 3
		end

		return 0
	end

	method void RefreshCoffeeShotButtonState(number index)
		local slot = self:GetCoffeeShotSlot(index)
		self:SetCoffeeShotButtonEnabled(index, self:CanBrewCoffeeShotFromSlot(slot))
	end

	method any GetCoffeeShotSlot(number index)
		if self.GameData == nil or self.GameData.CupSlots == nil then
			return nil
		end

		return self.GameData.CupSlots[index]
	end

	method ButtonComponent GetCoffeeShotButton(number index)
		if index == 1 then
			return self.btnCoffeeShot1
		end
		if index == 2 then
			return self.btnCoffeeShot2
		end
		if index == 3 then
			return self.btnCoffeeShot3
		end

		return nil
	end

	method boolean CanBrewCoffeeShotFromSlot(any slot)
		if slot == nil or slot.hasCup ~= true or slot.cupData == nil then
			return false
		end

		if slot.cupData.isPackaged == true then
			return false
		end

		if slot.isBrewingShot == true then
			return false
		end

		return true
	end

	method void SetCoffeeShotButtonEnabled(number index, boolean enabled)
		local button = self:GetCoffeeShotButton(index)
		if button == nil then
			return
		end

		button.Enable = enabled
		if button.Entity ~= nil then
			button.Entity.Enable = true
		end
	end

	method void InitializeWaterPourButton()
		self:RefreshWaterPourButtonState()
		self:SetButtonEffectVisible(self.btnColdWater, false)
	end

	method void InitializeSteamButton()
		self:RefreshSteamButtonState()
	end

	method void InitializePackageButton()
		if self.btnHotCup ~= nil and self.btnHotCup.Entity ~= nil and self.btnHotCup.Entity.TextComponent ~= nil then
			self.btnHotCup.Entity.TextComponent.Text = "포장"
		end
		self:RefreshPackageButtonState()
	end

	method void RefreshPackageButtonState()
		self:SetPackageButtonEnabled(true)
	end

	method void SetPackageButtonEnabled(boolean enabled)
		if self.btnHotCup == nil then
			return
		end

		self.btnHotCup.Enable = enabled
		if self.btnHotCup.Entity ~= nil then
			self.btnHotCup.Entity.Enable = true
		end
	end

	method any GetWaterPourSlot()
		if self.GameData == nil or self.GameData.CupSlots == nil then
			return nil
		end

		return self.GameData.CupSlots[5]
	end

	method void RefreshWaterPourButtonState()
		self:SetWaterPourButtonEnabled(self:CanUseWaterButton())
	end

	method boolean CanUseWaterButton()
		local slot = self:GetWaterPourSlot()
		if slot ~= nil and slot.isPouringWater == true then
			return false
		end

		return self:CanPourWaterFromSlot(slot)
	end

	method boolean CanPourWaterFromSlot(any slot)
		if slot == nil or slot.hasCup ~= true or slot.cupData == nil then
			return false
		end

		if slot.cupData.isPackaged == true then
			return false
		end

		if slot.isPouringWater == true then
			return false
		end

		return self:GetWaterIngredientIdForCup(slot.cupData) ~= ""
	end

	method void SetWaterPourButtonEnabled(boolean enabled)
		if self.btnColdWater == nil then
			return
		end

		self.btnColdWater.Enable = enabled
		if self.btnColdWater.Entity ~= nil then
			self.btnColdWater.Entity.Enable = true
		end
	end

	method any GetSteamSlot()
		return self:GetWaterPourSlot()
	end

	method void RefreshSteamButtonState()
		local slot = self:GetSteamSlot()
		self:SetSteamButtonEnabled(self:CanSteamCupFromSlot(slot))
	end

	method boolean CanSteamCupFromSlot(any slot)
		if slot == nil or slot.hasCup ~= true or slot.cupData == nil then
			return false
		end

		if slot.cupData.isPackaged == true then
			return false
		end

		if slot.isSteaming == true then
			return false
		end

		if slot.cupData.isSteamed == true then
			return false
		end

		return self:CupHasIngredient(slot.cupData, "Water")
	end

	method boolean CupHasIngredient(any cupData, string ingredientId)
		if cupData == nil or cupData.ingredients == nil then
			return false
		end

		for index = 1, #cupData.ingredients do
			if cupData.ingredients[index] == ingredientId then
				return true
			end
		end

		return false
	end

	method void SetSteamButtonEnabled(boolean enabled)
		if self.btnSteam == nil then
			return
		end

		self.btnSteam.Enable = enabled
		if self.btnSteam.Entity ~= nil then
			self.btnSteam.Entity.Enable = true
		end
	end

	method string GetWaterIngredientIdForCup(any cupData)
		if cupData == nil then
			return ""
		end

		if cupData.type == "HotCup" or cupData.type == "IceCup" or cupData.type == "ColdCup" then
			return "Water"
		end

		return ""
	end

	method void ShowSelectedButtonVisual(ButtonComponent button)
		-- 현재 선택된 버튼은 노란 외곽선으로 표시한다.
		if _UISlotViewService ~= nil then
			_UISlotViewService:ShowSelectedButtonVisual(self, button)
			return
		end
		
		log("UISlotViewService is not loaded.")
	end

	method void ClearSelectedButtonVisual()
		-- 이전 선택 표시를 기본 외곽선으로 되돌린다.
		if _UISlotViewService ~= nil then
			_UISlotViewService:ClearSelectedButtonVisual(self)
			return
		end
		
		log("UISlotViewService is not loaded.")
	end

	method void ConnectGameButtons()
		-- UI 버튼과 게임 로직의 클릭 핸들러를 한 번에 연결한다.
		log("Connect game buttons")
		
		self.btnIceCup.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupTypeButton("IceCup", self.btnIceCup) end)
		self.btnHotCup.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickPackageButton(self.btnHotCup) end)
		self.btnIceMaker.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIceMakerButton(self.btnIceMaker) end)
		self.btnColdWater.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickWaterButton(self.btnColdWater) end)
		self.btnSteam.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickSteamButton(self.btnSteam) end)
		self.btnCoffeeShot1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCoffeeShotButton(1, self.btnCoffeeShot1) end)
		self.btnCoffeeShot2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCoffeeShotButton(2, self.btnCoffeeShot2) end)
		self.btnCoffeeShot3.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCoffeeShotButton(3, self.btnCoffeeShot3) end)
		
		self.btnIng1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(1), self.btnIng1) end)
		self.btnIng2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(2), self.btnIng2) end)
		self.btnIng3.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(3), self.btnIng3) end)
		self.btnIng4.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(4), self.btnIng4) end)
		self.btnIng5.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(5), self.btnIng5) end)
		self.btnIng6.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(6), self.btnIng6) end)
		self.btnIng7.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(7), self.btnIng7) end)
		self.btnIng8.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton(self:GetIngredientButtonId(8), self.btnIng8) end)
		
		self.slotCup1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[1], self.slotCup1) end)
		self.slotCup2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[2], self.slotCup2) end)
		self.slotCup3.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[3], self.slotCup3) end)
		self.slotCup4.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[4], self.slotCup4) end)
		self.slotCup5.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[5], self.slotCup5) end)
		
		self.slotIng1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientSlot(self.GameData.IngredientSlots[1], self.slotIng1) end)
		self.slotIng2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientSlot(self.GameData.IngredientSlots[2], self.slotIng2) end)
		self:ConnectIngredientSlotCharacterButton(1, self.slotIng1)
		self:ConnectIngredientSlotCharacterButton(2, self.slotIng2)
		
		self.slotMixer1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickMixer(self.GameData.Mixers[1], self.slotMixer1) end)
		self.slotMixer2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickMixer(self.GameData.Mixers[2], self.slotMixer2) end)
		self:ConnectMixerCharacterButton(1, self.slotMixer1)
		self:ConnectMixerCharacterButton(2, self.slotMixer2)
		self.btnDiscardAction.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickDiscardAction() end)
		-- DH 테스트용 버튼
		if self.btnSubmitDrinkTest ~= nil then
			self.btnSubmitDrinkTest.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickSubmitDrinkTest() end)
		end
		
		log("Game buttons connected")
	end

	method void ConnectIngredientSlotCharacterButton(number index, ButtonComponent slotButton)
		if slotButton == nil or slotButton.Entity == nil then
			return
		end

		local characterEntity = slotButton.Entity:GetChildByName("Character", true)
		if characterEntity == nil then
			log("Ingredient slot character button is not found: " .. tostring(index))
			return
		end

		characterEntity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientSlotCharacterButton(index) end)
	end

	method void OnClickIngredientSlotCharacterButton(number index)
		if self.IsPaused == true then
			return
		end

		if self.GameData == nil or self.GameData.IngredientSlots == nil then
			return
		end

		local slot = self.GameData.IngredientSlots[index]
		if slot == nil then
			return
		end

		self:StartClickPrepIngredientSlot(slot)
	end

	method void StartClickPrepIngredientSlot(any slot)
		if slot == nil or slot.state ~= "RAW" then
			return
		end

		if self:CanPrepIngredient(slot.ingredientId) == false then
			return
		end

		if self.SelectionManager ~= nil and self.SelectionManager.state == "INGREDIENT_SLOT" and self.SelectionManager.data == slot then
			self.SelectionManager:Clear()
		end

		self:StartPrepIngredientSlot(slot)
	end

	method void ConnectMixerCharacterButton(number index, ButtonComponent slotButton)
		if slotButton == nil or slotButton.Entity == nil then
			return
		end

		local characterEntity = slotButton.Entity:GetChildByName("Character", true)
		if characterEntity == nil then
			log("Mixer character button is not found: " .. tostring(index))
			return
		end

		characterEntity:ConnectEvent(ButtonClickEvent, function() self:OnClickMixerCharacterButton(index) end)
	end

	method void OnClickMixerCharacterButton(number index)
		if self.IsPaused == true then
			return
		end

		if self.GameData == nil or self.GameData.Mixers == nil then
			return
		end

		local mixer = self.GameData.Mixers[index]
		if mixer == nil then
			return
		end

		local selectionState = "NONE"
		if self.SelectionManager ~= nil then
			selectionState = self.SelectionManager.state
		end

		local canStartFromClick = false
		if self.SelectionManager ~= nil and selectionState == "MIXER" and self.SelectionManager.data == mixer then
			canStartFromClick = true
		end

		if canStartFromClick == true and mixer.isMixed == false and mixer.isMixing ~= true and mixer.ingredients ~= nil and (#mixer.ingredients > 0 or mixer.hasInvalidRecipeIngredient == true) then
			if self.SelectionManager ~= nil and self.SelectionManager.state == "MIXER" and self.SelectionManager.data == mixer then
				self.SelectionManager:Clear()
			end
			self:StartMixMixer(mixer)
			return
		end

		if self.SelectionManager ~= nil then
			self.SelectionManager:HandleClick("MIXER", mixer)
			return
		end

		log("Cannot handle mixer click from character: " .. tostring(mixer.id))
	end

	method void OnClickSubmitDrinkTest()
		if self.IsPaused == true then
			return
		end

		local slot = self:GetSelectedCupSlot()
		if slot ~= nil and (slot.cupData == nil or slot.cupData.isPackaged ~= true) then
			log("Submit failed. Package the drink first.")
			return
		end
		if slot == nil then
			slot = self:GetFirstPackagedCupSlot()
		end
		if slot == nil then
			log("Submit failed. No packaged drink.")
			return
		end

		self:SubmitCupSlot(slot)
	end

	method boolean SubmitCupSlot(any slot)
		if slot == nil or slot.hasCup ~= true or slot.cupData == nil then
			return false
		end

		if slot.cupData.isPackaged ~= true then
			log("Submit failed. Package the drink first.")
			return false
		end

		local dayManager = self:GetDayManager()
		if dayManager == nil then
			log("Submit failed. DayManager is not found.")
			return false
		end

		local success = dayManager:SubmitCupData(slot.cupData)
		if success == false then
			return false
		end

		slot.hasCup = false
		slot.cupData = nil
		self:RefreshCupSlotImage(slot)
		self:SetPrepSlotProgress(slot, 0)
		self:ClearOrderPreview()
		if self.SelectionManager ~= nil then
			self.SelectionManager:Clear()
		end
		return true
	end

	method any GetSelectedCupSlot()
		if self.SelectionManager == nil then
			return nil
		end
		if self.SelectionManager.state == "PLACED_CUP" and self.SelectionManager.data ~= nil then
			return self.SelectionManager.data
		end
		return nil
	end

	method any GetFirstFilledCupSlot()
		if self.GameData == nil or self.GameData.CupSlots == nil then
			return nil
		end
		for i = 1, #self.GameData.CupSlots do
			local slot = self.GameData.CupSlots[i]
			if slot.hasCup == true and slot.cupData ~= nil then
				return slot
			end
		end
		return nil
	end

	method any GetDayManager()
		if self.DayManagerPath == nil or self.DayManagerPath == "" then
			return nil
		end
		local entity = _EntityService:GetEntityByPath(self.DayManagerPath)
		if entity == nil then
			return nil
		end
		return entity.DayManager
	end

	method any GetCustomerTable()
		if self.CustomerTablePath == nil or self.CustomerTablePath == "" then
			return nil
		end
		local entity = _EntityService:GetEntityByPath(self.CustomerTablePath)
		if entity == nil then
			return nil
		end
		return entity.CustomerTableComponent
	end

	method void PreviewCupOrderMatches(any cupData)
		local customerTable = self:GetCustomerTable()
		if customerTable ~= nil then
			customerTable:PreviewCupOrderMatches(cupData)
		end
	end

	method void ClearOrderPreview()
		local customerTable = self:GetCustomerTable()
		if customerTable ~= nil then
			customerTable:ClearOrderPreview()
		end
	end

	method void OnClickIngredientButton(string ingredientId, ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		-- 아래쪽 고정 버튼들은 선택 상태만 바꾸고, 실제 상호작용은 SelectionManager가 판단한다.
		if ingredientId == nil or ingredientId == "" then
			log("Ingredient button is not mapped.")
			return
		end
		
		log("Clicked ingredient button: " .. ingredientId)
		self.SelectionManager:HandleClick("INGREDIENT_BTN", { ingredientId = ingredientId, uiButton = sourceButton })
	end

	method void OnClickCupTypeButton(string cupType, ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		log("Clicked cup type button: " .. cupType)
		self.SelectionManager:HandleClick("CUP_TYPE_BTN", { cupType = cupType, uiButton = sourceButton })
	end

	method void OnClickPackageButton(ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		local sourceSlot = self:GetSelectedCupSlot()
		if sourceSlot == nil or self:IsPackageSlot(sourceSlot) == true then
			sourceSlot = self:GetFirstPackageableCupSlot()
		end
		if sourceSlot == nil then
			log("Cannot package cup. Select a completed drink first.")
			return
		end

		if self:PackageCupSlot(sourceSlot, nil) == true and self.SelectionManager ~= nil then
			self.SelectionManager:Clear()
		end
	end

	method void OnClickIceMakerButton(ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		if self.SelectionManager ~= nil and self.SelectionManager.state == "MIXER" then
			local mixer = self.SelectionManager.data
			if mixer ~= nil and mixer.isMixed == false and mixer.isMixing ~= true then
				if self:AddIngredientToMixer(mixer, "Ice") == true then
					self.SelectionManager:Clear()
				elseif mixer.hasInvalidRecipeIngredient == true then
					self.SelectionManager:Select("MIXER", mixer)
				end
				return
			end
		end

		log("Clicked ice maker button")
		self.SelectionManager:HandleClick("ICE_MAKER_BTN", { uiButton = sourceButton })
	end

	method void OnClickWaterButton(ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		if self.SelectionManager ~= nil and self.SelectionManager.state == "MIXER" then
			log("Water cannot be added to mixer. Use ice instead.")
			local mixer = self.SelectionManager.data
			self:MarkMixerInvalidRecipeIngredient(mixer, "Water")
			if mixer ~= nil then
				self.SelectionManager:Select("MIXER", mixer)
			else
				self.SelectionManager:Clear()
			end
			return
		end

		local slot = self:GetWaterPourSlot()
		if self:CanPourWaterFromSlot(slot) == false then
			log("Cannot pour water. Put a cup in CupSlot_5.")
			self:RefreshWaterPourButtonState()
			return
		end

		log("Clicked water pour button")
		self:StartPourWater(slot)
	end

	method void OnClickCoffeeShotButton(number index, ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		local slot = self:GetCoffeeShotSlot(index)
		if self:CanBrewCoffeeShotFromSlot(slot) == false then
			log("Cannot brew coffee shot. CupSlot_" .. tostring(index) .. " is empty or unavailable.")
			self:RefreshCoffeeShotButtonState(index)
			return
		end

		local coffeeShotId = "CoffeeShot_" .. tostring(index)
		log("Clicked coffee shot button: " .. coffeeShotId)
		self:StartCoffeeShot(slot, sourceButton, coffeeShotId)
	end

	method void OnClickSteamButton(ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		local slot = self:GetSteamSlot()
		if self:CanSteamCupFromSlot(slot) == false then
			log("Cannot steam cup. CupSlot_5 is empty or unavailable.")
			self:RefreshSteamButtonState()
			return
		end

		log("Clicked steam button")
		self:StartSteamCup(slot)
	end

	method void OnClickIngredientSlot(any slot, ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		log("Clicked ingredient slot: " .. slot.id)
		slot.uiButton = sourceButton
		self.SelectionManager:HandleClick("INGREDIENT_SLOT", slot)
	end

	method void OnClickCupSlot(any slot, ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		self:LogCupSlotInfo(slot)
		slot.uiButton = sourceButton
		self.SelectionManager:HandleClick("CUP_SLOT", slot)

		if self:GetSelectedCupSlot() == slot and slot.hasCup == true then
			self:PreviewCupOrderMatches(slot.cupData)
		else
			self:ClearOrderPreview()
		end
	end

	method string GetIngredientListText(any cupData)
		if cupData == nil or cupData.ingredients == nil or #cupData.ingredients == 0 then
			return "empty"
		end
		
		local text = ""
		for index, ingredientId in pairs(cupData.ingredients) do
			if text ~= "" then
				text = text .. ", "
			end
			text = text .. ingredientId
		end
		
		return text
	end

	method void OnClickMixer(any mixer, ButtonComponent sourceButton)
		if self.IsPaused == true then
			return
		end

		log("Clicked mixer: " .. mixer.id)
		mixer.uiButton = sourceButton
		self.SelectionManager:HandleClick("MIXER", mixer)
	end

	method void OnClickEmptySpace()
		if self.IsPaused == true then
			return
		end

		log("Clicked empty space")
		self.SelectionManager:HandleClick("EMPTY", {})
		self:ClearOrderPreview()
	end

	method void OnClickUIAction(string action)
		if self.IsPaused == true then
			return
		end

		log("Clicked UI action: " .. action)
		self.SelectionManager:HandleUIAction(action)
	end

	method void OnClickPrepAction()
		if self.IsPaused == true then
			return
		end

		log("Clicked prep action")
		self.SelectionManager:HandleUIAction("PREP")
	end

	method void OnClickMixAction()
		if self.IsPaused == true then
			return
		end

		log("Clicked mix action")
		self.SelectionManager:HandleUIAction("MIX")
	end

	method void OnClickDiscardAction()
		if self.IsPaused == true then
			return
		end

		log("Clicked discard action")
		self.SelectionManager:HandleUIAction("DISCARD")
	end

end
