@Logic
script ServiceManager extends Logic

	property any GameData = nil

	property any SelectionManager = nil

	property any selectedButtonEntity = nil

	property any selectedButtonSpriteEntity = nil

	property any selectedButtonSpriteOriginalPosition = nil

	property any prepTargetSlot = nil

	property any brewShotTargetSlot = nil

	property any mixTargetMixer = nil

	property any actionButtonConfigs = nil

	property any actionButtonTweenIds = nil

	property any progressTimerIds = nil

	property any progressTimerTargets = nil

	property boolean IsPaused = false

	property string DrinkDataSetName = "CustomerDrinkData"

	property string cupImageRUID = "c1cc66398f0e42d5be21315c1adeb34c"

	property string hotCupImageRUID = "c1cc66398f0e42d5be21315c1adeb34c"

	property number iceCupImageWidth = 138

	property number iceCupImageHeight = 166

	property number hotCupImageWidth = 138

	property number hotCupImageHeight = 166

	property number packagedDrinkImageWidth = 138

	property number packagedDrinkImageHeight = 166

	property string trashMixerImageRUID = "ecb3942bc998487d97a3df4dca2b815c"

	property number trashMixerImageWidth = 118

	property number trashMixerImageHeight = 112

	property number prepDuration = 1.5

	property number brewShotDuration = 1

	property number mixDuration = 1.5

	property number waterPourDuration = 1

	property number steamDuration = 1

	property number prepButtonShowX = 880

	property number prepButtonHideX = 1040

	property number prepButtonY = 0

	property number prepButtonTweenDuration = 0.15

	property number brewShotButtonY = -95

	property number mixButtonY = -190

	property number discardButtonX = 0

	property number discardButtonShowY = -460

	property number discardButtonHideY = -620

	property ButtonComponent btnIceCup = "c3ca0001-cafe-cafe-cafe-c3cafe000002"

	property ButtonComponent btnHotCup = "c3ca0001-cafe-cafe-cafe-c3cafe000003"

	property ButtonComponent btnIceMaker = "c3ca0001-cafe-cafe-cafe-c3cafe000004"

	property ButtonComponent btnColdWater = "c3ca0001-cafe-cafe-cafe-c3cafe000005"

	property ButtonComponent btnSteam = "c3ca0001-cafe-cafe-cafe-c3cafe000006"

	property ButtonComponent btnCoffeeShot1 = "483b9289-aaf1-42eb-bcec-31d4ed1ca5e5"

	property ButtonComponent btnCoffeeShot2 = "7da527da-cb35-4b11-b654-aeffdfcbe67b"

	property ButtonComponent btnCoffeeShot3 = "dc9a024e-4f33-4a6f-92f0-23a044c051be"

	property ButtonComponent btnIng1 = "c3ca0001-cafe-cafe-cafe-c3cafe000007"

	property ButtonComponent btnIng2 = "c3ca0001-cafe-cafe-cafe-c3cafe000008"

	property ButtonComponent btnIng3 = "c3ca0001-cafe-cafe-cafe-c3cafe000009"

	property ButtonComponent btnIng4 = "c3ca0001-cafe-cafe-cafe-c3cafe000010"

	property ButtonComponent btnIng5 = "c3ca0001-cafe-cafe-cafe-c3cafe000011"

	property ButtonComponent btnIng6 = "c3ca0001-cafe-cafe-cafe-c3cafe000012"

	property ButtonComponent btnIng7 = "c3ca0001-cafe-cafe-cafe-c3cafe000013"

	property ButtonComponent btnIng8 = "c3ca0001-cafe-cafe-cafe-c3cafe000014"

	property ButtonComponent slotCup1 = "c3ca0001-cafe-cafe-cafe-c3cafe000015"

	property ButtonComponent slotCup2 = "c3ca0001-cafe-cafe-cafe-c3cafe000016"

	property ButtonComponent slotCup3 = "c3ca0001-cafe-cafe-cafe-c3cafe000017"

	property ButtonComponent slotCup4 = "c3ca0001-cafe-cafe-cafe-c3cafe000018"

	property ButtonComponent slotCup5 = "c3ca0001-cafe-cafe-cafe-c3cafe000019"

	property ButtonComponent slotIng1 = "c3ca0001-cafe-cafe-cafe-c3cafe000020"

	property ButtonComponent slotIng2 = "c3ca0001-cafe-cafe-cafe-c3cafe000021"

	property ButtonComponent slotMixer1 = "c3ca0001-cafe-cafe-cafe-c3cafe000022"

	property ButtonComponent slotMixer2 = "c3ca0001-cafe-cafe-cafe-c3cafe000023"

	property ButtonComponent btnPrepAction = "c3ca0001-cafe-cafe-cafe-c3cafe000025"

	property ButtonComponent btnBrewShotAction = "c3ca0001-cafe-cafe-cafe-c3cafe000026"

	property ButtonComponent btnMixAction = "c3ca0001-cafe-cafe-cafe-c3cafe000027"

	property ButtonComponent btnDiscardAction = "c3ca0001-cafe-cafe-cafe-c3cafe000028"

	property ButtonComponent btnSubmitDrinkTest = "58a48f10-8757-4d45-a6b0-cafb05090101"

	property string DayManagerPath = "/ui/DayInfoGroup/DayManager"

	property string CustomerTablePath = "/ui/CustomerUIGroup/CustomerTable"

	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- ServiceManager는 데이터 생성, 선택 규칙, UI 버튼 연결을 조율하는 시작점이다.
		self.GameData = self:CreateInitialGameData()
		self.SelectionManager = self:CreateInitialSelectionManager()
		if self.GameData == nil or self.SelectionManager == nil then
			log("ServiceManager cannot start. Required service script is not loaded.")
			return
		end
		
		self:InitializeActionButtons()
		self:InitializeWorkProcesses()
		self:BindSlotButtons()
		self:InitializeIngredientButtons()
		self:ConnectGameButtons()
		self:HideActionButtonsImmediately()
		self:InitializeCoffeeShotButtons()
		self:InitializeWaterPourButton()
		self:InitializeSteamButton()
		self:InitializePackageButton()
	end

	method any CreateInitialGameData()
		-- 데이터 생성 책임은 DataFactory만 가진다.
		if _DataFactory ~= nil then
			return _DataFactory:CreateGameData()
		end
		
		log("DataFactory is not loaded.")
		return nil
	end

	method any CreateInitialSelectionManager()
		-- 선택 규칙 생성 책임은 SelectionManagerFactory만 가진다.
		if _SelectionManagerFactory ~= nil then
			return _SelectionManagerFactory:CreateSelectionManager(self)
		end
		
		log("SelectionManagerFactory is not loaded.")
		return nil
	end

	method void InitializeActionButtons()
		if _UIActionButtonService ~= nil then
			_UIActionButtonService:Initialize(self)
			return
		end
		
		log("UIActionButtonService is not loaded.")
		self.actionButtonConfigs = {}
		self.actionButtonTweenIds = {}
	end

	method void InitializeWorkProcesses()
		if _WorkProcessService ~= nil then
			_WorkProcessService:Initialize(self)
			return
		end
		
		log("WorkProcessService is not loaded.")
		self.progressTimerIds = {}
		self.progressTimerTargets = {}
	end

	method void ResetServiceStateForDay()
		-- Day가 바뀔 때 제작대에 남은 선택/작업/컵 상태를 전부 새로 시작한다.
		self.IsPaused = false
		self:ClearAllProgressTimers()
		self.prepTargetSlot = nil
		self.brewShotTargetSlot = nil
		self.mixTargetMixer = nil

		if self.SelectionManager ~= nil then
			self.SelectionManager:Clear()
		else
			self:ClearSelectedButtonVisual()
			self:HideActionButtonsImmediately()
			self:ClearOrderPreview()
		end
		self:HideActionButtonsImmediately()

		self.GameData = self:CreateInitialGameData()
		if self.SelectionManager == nil then
			self.SelectionManager = self:CreateInitialSelectionManager()
		end

		self:BindSlotButtons()
		self:InitializeIngredientButtons()
		self:ResetSlotViewsForDay()
		self:InitializeCoffeeShotButtons()
		self:RefreshWaterPourButtonState()
		self:RefreshSteamButtonState()
		self:RefreshPackageButtonState()
		self:ClearOrderPreview()
	end

	method void ClearAllProgressTimers()
		if self.progressTimerIds ~= nil and _TimerService ~= nil then
			for timerKey, timerId in pairs(self.progressTimerIds) do
				if timerId ~= nil and timerId ~= 0 then
					_TimerService:ClearTimer(timerId)
				end
			end
		end
		if self.progressTimerTargets ~= nil and _WorkProcessService ~= nil then
			for timerKey, target in pairs(self.progressTimerTargets) do
				_WorkProcessService:SetPrepSlotProgress(target, 0)
			end
		end

		self.progressTimerIds = {}
		self.progressTimerTargets = {}
	end

	method void BindSlotButtons()
		if self.GameData == nil then
			return
		end

		self:BindSlotButton(self.GameData.CupSlots, 1, self.slotCup1)
		self:BindSlotButton(self.GameData.CupSlots, 2, self.slotCup2)
		self:BindSlotButton(self.GameData.CupSlots, 3, self.slotCup3)
		self:BindSlotButton(self.GameData.CupSlots, 4, self.slotCup4)
		self:BindSlotButton(self.GameData.CupSlots, 5, self.slotCup5)

		self:BindSlotButton(self.GameData.IngredientSlots, 1, self.slotIng1)
		self:BindSlotButton(self.GameData.IngredientSlots, 2, self.slotIng2)

		self:BindSlotButton(self.GameData.Mixers, 1, self.slotMixer1)
		self:BindSlotButton(self.GameData.Mixers, 2, self.slotMixer2)
	end

	method void BindSlotButton(any slots, number index, ButtonComponent button)
		if slots == nil or slots[index] == nil then
			return
		end

		slots[index].uiButton = button
	end

	method void ResetSlotViewsForDay()
		if self.GameData == nil then
			return
		end

		self:ResetSlotCollectionViews(self.GameData.CupSlots)
		self:ResetSlotCollectionViews(self.GameData.IngredientSlots)
		self:ResetSlotCollectionViews(self.GameData.Mixers)
	end

	method void ResetSlotCollectionViews(any slots)
		if slots == nil then
			return
		end

		for i = 1, #slots do
			self:ResetSlotView(slots[i])
		end
	end

	method void ResetSlotView(any slot)
		if slot == nil then
			return
		end

		if slot.uiButton ~= nil then
			slot.uiButton.Enable = true
		end
		if slot.hasCup ~= nil then
			self:RefreshCupSlotImage(slot)
		elseif self:IsMixerSlotView(slot) == false then
			self:SetSlotImage(slot, "")
		end
		self:SetPrepSlotProgress(slot, 0)
		self:ClearMixerLayerImages(slot)
		self:SetSlotEffectVisible(slot, false)
	end

	method boolean IsMixerSlotView(any slot)
		if slot == nil or slot.uiButton == nil or slot.uiButton.Entity == nil then
			return false
		end

		return slot.uiButton.Entity.Name == "SlotMixer1" or slot.uiButton.Entity.Name == "SlotMixer2"
	end

	method string GetMixerResultId(any mixer)
		-- 믹서 관련 규칙은 MixerService에 위임한다.
		if _MixerService ~= nil then
			return _MixerService:GetMixerResultId(self, mixer)
		end
		
		log("MixerService is not loaded.")
		return ""
	end

	method boolean IsTrashMixerResult(any mixer)
		if _MixerService ~= nil then
			return _MixerService:IsTrashMixerResult(mixer)
		end
		
		log("MixerService is not loaded.")
		return false
	end

	method any CreateMixer(string mixerId)
		if _MixerService ~= nil then
			return _MixerService:CreateMixer(mixerId)
		end
		
		log("MixerService is not loaded.")
		return nil
	end

	method boolean AddIngredientToMixer(any mixer, string ingredientId)
		if _MixerService ~= nil then
			local added = _MixerService:AddIngredientToMixer(self, mixer, ingredientId)
			if added == true then
				self:RefreshMixerLayerImages(mixer)
			end
			return added
		end
		
		log("MixerService is not loaded.")
		return false
	end

	method void MarkMixerInvalidRecipeIngredient(any mixer, string ingredientId)
		if _MixerService ~= nil then
			_MixerService:MarkMixerInvalidRecipeIngredient(mixer, ingredientId)
			return
		end

		log("MixerService is not loaded.")
	end

	method string GetMixerRecipeKey(any mixer)
		if _MixerService ~= nil then
			return _MixerService:GetMixerRecipeKey(mixer)
		end
		
		log("MixerService is not loaded.")
		return ""
	end

	method void ClearMixer(any mixer)
		if _MixerService ~= nil then
			_MixerService:ClearMixer(self, mixer)
			self:ClearMixerLayerImages(mixer)
			self:SetMixerEffectVisible(mixer, false)
			return
		end
		
		log("MixerService is not loaded.")
	end

	method any CreateCup(string cupType)
		-- 컵 생성/재료 추가/정보 추출은 CupService에 위임하는 구조다.
		if _CupService ~= nil then
			return _CupService:CreateCup(cupType)
		end
		
		log("CupService is not loaded.")
		return nil
	end

	method boolean AddIngredientToCup(any cupData, string ingredientId)
		if _CupService ~= nil then
			local added = _CupService:AddIngredientToCup(self, cupData, ingredientId)
			if added == true then
				self:RefreshCupSlotByCupData(cupData)
			end
			return added
		end
		
		log("CupService is not loaded.")
		return false
	end

	method any GetIngredientDef(string ingredientId)
		-- 재료 규칙은 IngredientDefs 테이블 하나를 기준으로 조회한다.
		if self.GameData == nil or self.GameData.IngredientDefs == nil then
			return nil
		end
		
		return self.GameData.IngredientDefs[ingredientId]
	end

	method any GetMixedIngredientDef(string ingredientId)
		if ingredientId == nil or ingredientId == "" then
			return nil
		end
		if self.GameData == nil or self.GameData.MixedIngredientDefs == nil then
			return nil
		end

		return self.GameData.MixedIngredientDefs[ingredientId]
	end

	method any GetIngredientImageMap(string ingredientId)
		if ingredientId == nil or ingredientId == "" then
			return nil
		end
		if self.GameData == nil or self.GameData.IngredientImageMap == nil then
			return nil
		end
		
		return self.GameData.IngredientImageMap[ingredientId]
	end

	method string GetMappedIngredientImageRUID(string ingredientId, string imageField)
		if ingredientId == nil or ingredientId == "" then
			return ""
		end

		local imageMap = self:GetIngredientImageMap(ingredientId)
		if imageMap ~= nil then
			local imageRUID = imageMap[imageField]
			if imageRUID ~= nil and imageRUID ~= "" then
				return imageRUID
			end
			
			imageRUID = imageMap.prepImageRUID
			if imageRUID ~= nil and imageRUID ~= "" then
				return imageRUID
			end
		end

		if string.sub(ingredientId, 1, 8) == "prepped_" then
			local baseIngredientId = string.sub(ingredientId, 9)
			local baseImageRUID = self:GetMappedIngredientImageRUID(baseIngredientId, imageField)
			if baseImageRUID ~= nil and baseImageRUID ~= "" then
				return baseImageRUID
			end
		end

		local mixedDef = self:GetMixedIngredientDef(ingredientId)
		if mixedDef ~= nil and mixedDef.imageRUID ~= nil and mixedDef.imageRUID ~= "" then
			return mixedDef.imageRUID
		end
		
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.imageRUID ~= nil then
			return ingredientDef.imageRUID
		end
		
		return ""
	end

	method string GetPrepImageRUID(string ingredientId)
		if ingredientId == nil or ingredientId == "" then
			return ""
		end

		local imageMap = self:GetIngredientImageMap(ingredientId)
		if imageMap ~= nil and imageMap.prepImageRUID ~= nil and imageMap.prepImageRUID ~= "" then
			return imageMap.prepImageRUID
		end

		if string.sub(ingredientId, 1, 8) == "prepped_" then
			local baseIngredientId = string.sub(ingredientId, 9)
			local baseImageRUID = self:GetPrepImageRUID(baseIngredientId)
			if baseImageRUID ~= nil and baseImageRUID ~= "" then
				return baseImageRUID
			end
		end

		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.imageRUID ~= nil and ingredientDef.imageRUID ~= "" then
			return ingredientDef.imageRUID
		end

		return ""
	end

	method string GetCupLayerImageRUID(string ingredientId)
		return self:GetMappedIngredientImageRUID(ingredientId, "cupLayerImageRUID")
	end

	method string GetMixerImageRUID(string ingredientId)
		return self:GetMappedIngredientImageRUID(ingredientId, "mixerImageRUID")
	end

	method string GetMixedIngredientImageRUID(string ingredientId)
		if ingredientId == "Trash" then
			local imageRUID = self:GetMixerImageRUID(ingredientId)
			if imageRUID ~= nil and imageRUID ~= "" then
				return imageRUID
			end

			return self.trashMixerImageRUID
		end

		local mixedDef = self:GetMixedIngredientDef(ingredientId)
		if mixedDef ~= nil and mixedDef.imageRUID ~= nil then
			return mixedDef.imageRUID
		end

		return self:GetMixerImageRUID(ingredientId)
	end

	method number GetMixedIngredientImageWidth(string ingredientId)
		if ingredientId == "Trash" then
			return self.trashMixerImageWidth
		end

		local mixedDef = self:GetMixedIngredientDef(ingredientId)
		if mixedDef ~= nil and mixedDef.imageWidth ~= nil then
			return mixedDef.imageWidth
		end

		return 0
	end

	method number GetMixedIngredientImageHeight(string ingredientId)
		if ingredientId == "Trash" then
			return self.trashMixerImageHeight
		end

		local mixedDef = self:GetMixedIngredientDef(ingredientId)
		if mixedDef ~= nil and mixedDef.imageHeight ~= nil then
			return mixedDef.imageHeight
		end

		return 0
	end

	method string GetCupImageRUID(any cupData)
		if cupData ~= nil and cupData.type == "HotCup" then
			return self.hotCupImageRUID
		end

		return self.cupImageRUID
	end

	method number GetCupImageWidth(any cupData)
		if cupData ~= nil and cupData.type == "HotCup" then
			return self.hotCupImageWidth
		end

		return self.iceCupImageWidth
	end

	method number GetCupImageHeight(any cupData)
		if cupData ~= nil and cupData.type == "HotCup" then
			return self.hotCupImageHeight
		end

		return self.iceCupImageHeight
	end

	method boolean CanAddIngredientToCup(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canAddToCup ~= nil then
			return ingredientDef.canAddToCup
		end
		
		return true
	end

	method boolean CanAddIngredientToCupData(any cupData, string ingredientId)
		if cupData == nil then
			return false
		end

		if cupData.isPackaged == true then
			log("Cannot add ingredient to packaged cup: " .. tostring(ingredientId))
			return false
		end

		if self:CanAddIngredientToCup(ingredientId) == false then
			return false
		end

		if cupData.ingredients ~= nil then
			for index = 1, #cupData.ingredients do
				local existingIngredientId = cupData.ingredients[index]
				if self:IsFinalMixedIngredient(existingIngredientId) == true then
					log("Cup already has final ingredient: " .. existingIngredientId)
					return false
				end
			end
		end

		if self:IsFirstSlotOnlyMixedIngredient(ingredientId) == true then
			if cupData.ingredients ~= nil and #cupData.ingredients > 0 then
				log("Ingredient can only be added as first cup ingredient: " .. ingredientId)
				return false
			end
		end

		return true
	end

	method boolean IsFinalMixedIngredient(string ingredientId)
		local mixedDef = self:GetMixedIngredientDef(ingredientId)
		if mixedDef ~= nil and mixedDef.isFinalIngredient ~= nil then
			return mixedDef.isFinalIngredient
		end

		return false
	end

	method boolean IsFirstSlotOnlyMixedIngredient(string ingredientId)
		local mixedDef = self:GetMixedIngredientDef(ingredientId)
		if mixedDef ~= nil and mixedDef.firstSlotOnly ~= nil then
			return mixedDef.firstSlotOnly
		end

		return false
	end

	method boolean CanMixIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canMix ~= nil then
			return ingredientDef.canMix
		end
		
		return true
	end

	method boolean CanPrepIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canPrep ~= nil then
			return ingredientDef.canPrep
		end
		
		return false
	end

	method boolean IsCupSpaceIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		
		if ingredientDef ~= nil and ingredientDef.useCupSpace ~= nil then
			return ingredientDef.useCupSpace
		end
		
		return true
	end

	method string GetIngredientButtonId(number buttonIndex)
		if self.GameData == nil or self.GameData.IngredientButtonIds == nil then
			return ""
		end
		
		local ingredientId = self.GameData.IngredientButtonIds[buttonIndex]
		if ingredientId == nil then
			return ""
		end
		
		return ingredientId
	end

	method void InitializeIngredientButtons()
		for index = 1, 8 do
			self:RefreshIngredientButton(index)
		end
	end

	method void RefreshIngredientButton(number index)
		local button = self:GetIngredientButton(index)
		if button == nil or button.Entity == nil then
			return
		end

		local ingredientId = self:GetIngredientButtonId(index)
		if ingredientId == "" then
			button.Enable = false
			button.Entity.Enable = false
			return
		end

		button.Enable = true
		button.Entity.Enable = true
		self:SetIngredientButtonText(button, self:GetIngredientDisplayName(ingredientId))

		local imageRUID = self:GetIngredientButtonImageRUID(ingredientId)
		if imageRUID ~= "" then
			self:SetIngredientButtonImage(button, imageRUID)
		end
	end

	method string GetIngredientButtonImageRUID(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.imageRUID ~= nil and ingredientDef.imageRUID ~= "" then
			return ingredientDef.imageRUID
		end

		return self:GetPrepImageRUID(ingredientId)
	end

	method ButtonComponent GetIngredientButton(number index)
		if index == 1 then
			return self.btnIng1
		end
		if index == 2 then
			return self.btnIng2
		end
		if index == 3 then
			return self.btnIng3
		end
		if index == 4 then
			return self.btnIng4
		end
		if index == 5 then
			return self.btnIng5
		end
		if index == 6 then
			return self.btnIng6
		end
		if index == 7 then
			return self.btnIng7
		end
		if index == 8 then
			return self.btnIng8
		end

		return nil
	end

	method void SetIngredientButtonText(ButtonComponent button, string text)
		if button == nil or button.Entity == nil or button.Entity.TextComponent == nil then
			return
		end

		button.Entity.TextComponent.Text = text
	end

	method void SetIngredientButtonImage(ButtonComponent button, string imageRUID)
		if button == nil or button.Entity == nil then
			return
		end

		local spriteEntity = button.Entity:GetChildByName("UISprite", true)
		if spriteEntity == nil or spriteEntity.SpriteGUIRendererComponent == nil then
			return
		end

		spriteEntity.SpriteGUIRendererComponent.ImageRUID = DataRef(imageRUID)
	end

	method string GetIngredientDisplayName(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.displayName ~= nil and ingredientDef.displayName ~= "" then
			return ingredientDef.displayName
		end

		if string.sub(ingredientId, 1, 8) == "prepped_" then
			local baseIngredientId = string.sub(ingredientId, 9)
			ingredientDef = self:GetIngredientDef(baseIngredientId)
			if ingredientDef ~= nil and ingredientDef.displayName ~= nil and ingredientDef.displayName ~= "" then
				return ingredientDef.displayName
			end
		end

		local mixedDef = self:GetMixedIngredientDef(ingredientId)
		if mixedDef ~= nil and mixedDef.drinkName ~= nil and mixedDef.drinkName ~= "" then
			return mixedDef.drinkName
		end

		return ingredientId
	end

	method string GetCompletedDrinkImageRUID(any cupData)
		local completedDrink = self:GetCompletedDrinkInfo(cupData)
		if completedDrink == nil then
			return ""
		end

		if completedDrink.iconRUID ~= nil then
			return completedDrink.iconRUID
		end

		return ""
	end

	method string GetPackagedCupImageRUID(any cupData)
		if cupData == nil then
			return ""
		end

		if cupData.packagedDrinkImageRUID ~= nil and cupData.packagedDrinkImageRUID ~= "" then
			return cupData.packagedDrinkImageRUID
		end

		return self:GetCompletedDrinkImageRUID(cupData)
	end

	method number GetPackagedCupImageWidth(any cupData)
		if cupData ~= nil and cupData.packagedDrinkImageWidth ~= nil and cupData.packagedDrinkImageWidth > 0 then
			return cupData.packagedDrinkImageWidth
		end

		return self.packagedDrinkImageWidth
	end

	method number GetPackagedCupImageHeight(any cupData)
		if cupData ~= nil and cupData.packagedDrinkImageHeight ~= nil and cupData.packagedDrinkImageHeight > 0 then
			return cupData.packagedDrinkImageHeight
		end

		return self.packagedDrinkImageHeight
	end

	method any GetCompletedDrinkInfo(any cupData)
		local cupIngredients = self:GetCompletedCupDrinkIngredients(cupData)
		if cupIngredients == nil or #cupIngredients <= 0 then
			return nil
		end

		local cupCounts = self:CreateDrinkIngredientCounts(cupIngredients)
		local dataSetDrink = self:GetCompletedDrinkInfoFromDataSet(cupCounts)
		if dataSetDrink ~= nil then
			return dataSetDrink
		end

		return self:GetCompletedDrinkInfoFromFallback(cupCounts)
	end

	method table GetCompletedCupDrinkIngredients(any cupData)
		local ingredients = {}
		if cupData == nil or cupData.ingredients == nil then
			return ingredients
		end

		for index = 1, #cupData.ingredients do
			local ingredientId = self:NormalizeCupDrinkIngredientId(cupData, cupData.ingredients[index])
			if ingredientId ~= "" then
				table.insert(ingredients, ingredientId)
			end
		end

		return ingredients
	end

	method any GetCompletedDrinkInfoFromDataSet(table cupCounts)
		if _EntryService == nil or _DataService == nil then
			return nil
		end

		local dataSetId = _EntryService:GetDataSetIdByName(self.DrinkDataSetName)
		if dataSetId == nil or dataSetId == "" then
			return nil
		end

		local rowCount = _DataService:GetRowCount(self.DrinkDataSetName)
		for rowIndex = 1, rowCount do
			local drinkId = self:Trim(_DataService:GetCell(self.DrinkDataSetName, rowIndex, "Id"))
			local recipeText = self:Trim(_DataService:GetCell(self.DrinkDataSetName, rowIndex, "Ingredients"))
			if drinkId ~= "" and recipeText ~= "" then
				local recipeCounts = self:CreateDrinkIngredientCounts(self:ParseDrinkIngredientsText(recipeText))
				if self:AreDrinkIngredientCountsEqual(cupCounts, recipeCounts) == true then
					return {
						id = drinkId,
						iconRUID = self:Trim(_DataService:GetCell(self.DrinkDataSetName, rowIndex, "IconRUID")),
						imageWidth = self.packagedDrinkImageWidth,
						imageHeight = self.packagedDrinkImageHeight,
					}
				end
			end
		end

		return nil
	end

	method any GetCompletedDrinkInfoFromFallback(table cupCounts)
		local drinkDefs = self:GetFallbackDrinkDefinitions()
		for index = 1, #drinkDefs do
			local drinkDef = drinkDefs[index]
			local recipeCounts = self:CreateDrinkIngredientCounts(self:ParseDrinkIngredientsText(drinkDef.recipe))
			if self:AreDrinkIngredientCountsEqual(cupCounts, recipeCounts) == true then
				return drinkDef
			end
		end

		return nil
	end

	method table GetFallbackDrinkDefinitions()
		return {
			{ id = "HotAmericano", iconRUID = "1b21a0ed841f42f798f3623d0ff4a748", recipe = "CoffeeShot|HotWater", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "IceAmericano", iconRUID = "08b277dc4037414ca963307d196208b3", recipe = "CoffeeShot|ColdWater|Ice", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "Latte", iconRUID = "c63a6a0d311b45d2aafabbec52e9b294", recipe = "CoffeeShot|HotWater|Ingredient_1", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "Mocha", iconRUID = "2e47e7b814914617a5b785061c946d73", recipe = "CoffeeShot|HotWater|Ingredient_1|Ingredient_3", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "BamLatte", iconRUID = "e8b13faac0fb4e22828cb202431e5c35", recipe = "CoffeeShot|HotWater|Ingredient_1|prepped_Ingredient_5", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "StrawberrySmoothie", iconRUID = "2fcbf804078e47cb878088bf4e278cb5", recipe = "Mixed_Ingredient_1", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "BananaSmoothie", iconRUID = "e37e5eb0d6d24d71a6151f3075e122f8", recipe = "Mixed_Ingredient_2", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "SlimeBananaSmoothie", iconRUID = "ef1328c63c9047f5a98141b4fefc2769", recipe = "Mixed_Ingredient_3", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "QuattroSlimeSmoothie", iconRUID = "862c4875fb8b4ca6aafb9e03e488d6d4", recipe = "Mixed_Ingredient_4", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "ChocoFrappe", iconRUID = "c62d1aac184044bbb682ea579d68058b", recipe = "Mixed_Ingredient_5", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
			{ id = "MatchaFrappe", iconRUID = "66ccb9447f7c40768ce15b7afe6e0d4c", recipe = "Mixed_Ingredient_6", imageWidth = self.packagedDrinkImageWidth, imageHeight = self.packagedDrinkImageHeight },
		}
	end

	method table ParseDrinkIngredientsText(string ingredientsText)
		local ingredients = {}
		if ingredientsText == nil or ingredientsText == "" then
			return ingredients
		end

		for ingredientId in string.gmatch(ingredientsText, "([^|]+)") do
			local normalized = self:NormalizeDrinkIngredientId(ingredientId)
			if normalized ~= "" then
				table.insert(ingredients, normalized)
			end
		end

		return ingredients
	end

	method table CreateDrinkIngredientCounts(table ingredients)
		local counts = {}
		if ingredients == nil then
			return counts
		end

		for index = 1, #ingredients do
			local ingredientId = ingredients[index]
			if ingredientId ~= nil and ingredientId ~= "" then
				counts[ingredientId] = (counts[ingredientId] or 0) + 1
			end
		end

		return counts
	end

	method boolean AreDrinkIngredientCountsEqual(table left, table right)
		for ingredientId, count in pairs(left) do
			if right[ingredientId] ~= count then
				return false
			end
		end

		for ingredientId, count in pairs(right) do
			if left[ingredientId] ~= count then
				return false
			end
		end

		return true
	end

	method string NormalizeCupDrinkIngredientId(any cupData, string ingredientId)
		local value = self:NormalizeDrinkIngredientId(ingredientId)
		if value ~= "Water" then
			return value
		end

		if cupData ~= nil and cupData.isSteamed == true then
			return "HotWater"
		end

		return "ColdWater"
	end

	method string NormalizeDrinkIngredientId(string ingredientId)
		local value = self:Trim(ingredientId)
		if value == "" then
			return ""
		end

		if value == "CoffeeShot_1" or value == "CoffeeShot_2" or value == "CoffeeShot_3" then
			return "CoffeeShot"
		end

		local legacyPreppedIndex = string.match(value, "^prepped_Ingredient_([123])$")
		if legacyPreppedIndex ~= nil then
			return "Ingredient_" .. legacyPreppedIndex
		end

		local mixedIngredientIndex = string.match(value, "^Mixed_Cold_Ingredient_(%d+)$")
		if mixedIngredientIndex == nil then
			mixedIngredientIndex = string.match(value, "^Mixed_Hot_Ingredient_(%d+)$")
		end
		if mixedIngredientIndex ~= nil then
			return "Mixed_Ingredient_" .. mixedIngredientIndex
		end

		return self:ResolveDrinkIngredientDisplayName(value)
	end

	method string ResolveDrinkIngredientDisplayName(string value)
		if self.GameData ~= nil and self.GameData.IngredientDefs ~= nil then
			if self.GameData.IngredientDefs[value] ~= nil then
				return value
			end

			for ingredientId, ingredientDef in pairs(self.GameData.IngredientDefs) do
				if ingredientDef ~= nil and ingredientDef.displayName == value then
					return ingredientId
				end
			end
		end

		if self.GameData ~= nil and self.GameData.MixedIngredientDefs ~= nil then
			if self.GameData.MixedIngredientDefs[value] ~= nil then
				return value
			end

			for ingredientId, mixedDef in pairs(self.GameData.MixedIngredientDefs) do
				if mixedDef ~= nil and mixedDef.drinkName == value then
					return ingredientId
				end
			end
		end

		return value
	end

	method string Trim(string value)
		if value == nil then
			return ""
		end

		return (string.gsub(value, "^%s*(.-)%s*$", "%1"))
	end

