	method any GetIngredientDef(string ingredientId)
		-- 재료 규칙은 IngredientDefs 테이블 하나를 기준으로 조회한다.
		if self.GameData == nil or self.GameData.IngredientDefs == nil then
			return nil
		end
		
		return self.GameData.IngredientDefs[ingredientId]
	end

	method boolean CanAddIngredientToCup(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canAddToCup ~= nil then
			return ingredientDef.canAddToCup
		end
		
		return true
	end

	method boolean CanMixIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canMix ~= nil then
			return ingredientDef.canMix
		end
		
		return true
	end

	method boolean CanPrepIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canPrep ~= nil then
			return ingredientDef.canPrep
		end
		
		return false
	end

	method boolean IsCupSpaceIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		
		if ingredientDef ~= nil and ingredientDef.useCupSpace ~= nil then
			return ingredientDef.useCupSpace
		end
		
		return true
	end

	method string GetIngredientButtonId(number buttonIndex)
		if self.GameData == nil or self.GameData.IngredientButtonIds == nil then
			return ""
		end
		
		local ingredientId = self.GameData.IngredientButtonIds[buttonIndex]
		if ingredientId == nil then
			return ""
		end
		
		return ingredientId
	end

