	@ExecSpace("ClientOnly")
	method void OnBeginPlay()
		-- ServiceManager는 데이터 생성, 선택 규칙, UI 버튼 연결을 조율하는 시작점이다.
		self.GameData = self:CreateInitialGameData()
		self.SelectionManager = self:CreateInitialSelectionManager()
		if self.GameData == nil or self.SelectionManager == nil then
			log("ServiceManager cannot start. Required service script is not loaded.")
			return
		end
		
		self:InitializeActionButtons()
		self:InitializeWorkProcesses()
		self:BindSlotButtons()
		self:ConnectGameButtons()
		self:HideActionButtonsImmediately()
	end

	method any CreateInitialGameData()
		-- 데이터 생성 책임은 DataFactory만 가진다.
		if _DataFactory ~= nil then
			return _DataFactory:CreateGameData()
		end
		
		log("DataFactory is not loaded.")
		return nil
	end

	method any CreateInitialSelectionManager()
		-- 선택 규칙 생성 책임은 SelectionManagerFactory만 가진다.
		if _SelectionManagerFactory ~= nil then
			return _SelectionManagerFactory:CreateSelectionManager(self)
		end
		
		log("SelectionManagerFactory is not loaded.")
		return nil
	end

	method void InitializeActionButtons()
		if _UIActionButtonService ~= nil then
			_UIActionButtonService:Initialize(self)
			return
		end
		
		log("UIActionButtonService is not loaded.")
		self.actionButtonConfigs = {}
		self.actionButtonTweenIds = {}
	end

	method void InitializeWorkProcesses()
		if _WorkProcessService ~= nil then
			_WorkProcessService:Initialize(self)
			return
		end
		
		log("WorkProcessService is not loaded.")
		self.progressTimerIds = {}
		self.progressTimerTargets = {}
	end

	method void ResetServiceStateForDay()
		-- Day가 바뀔 때 제작대에 남은 선택/작업/컵 상태를 전부 새로 시작한다.
		self.IsPaused = false
		self:ClearAllProgressTimers()
		self.prepTargetSlot = nil
		self.brewShotTargetSlot = nil
		self.mixTargetMixer = nil

		if self.SelectionManager ~= nil then
			self.SelectionManager:Clear()
		else
			self:ClearSelectedButtonVisual()
			self:HideActionButtonsImmediately()
			self:ClearOrderPreview()
		end
		self:HideActionButtonsImmediately()

		self.GameData = self:CreateInitialGameData()
		if self.SelectionManager == nil then
			self.SelectionManager = self:CreateInitialSelectionManager()
		end

		self:BindSlotButtons()
		self:ResetSlotViewsForDay()
		self:ClearOrderPreview()
	end

	method void ClearAllProgressTimers()
		if self.progressTimerIds ~= nil and _TimerService ~= nil then
			for timerKey, timerId in pairs(self.progressTimerIds) do
				if timerId ~= nil and timerId ~= 0 then
					_TimerService:ClearTimer(timerId)
				end
			end
		end
		if self.progressTimerTargets ~= nil and _WorkProcessService ~= nil then
			for timerKey, target in pairs(self.progressTimerTargets) do
				_WorkProcessService:SetPrepSlotProgress(target, 0)
			end
		end

		self.progressTimerIds = {}
		self.progressTimerTargets = {}
	end

	method void BindSlotButtons()
		if self.GameData == nil then
			return
		end

		self:BindSlotButton(self.GameData.CupSlots, 1, self.slotCup1)
		self:BindSlotButton(self.GameData.CupSlots, 2, self.slotCup2)
		self:BindSlotButton(self.GameData.CupSlots, 3, self.slotCup3)
		self:BindSlotButton(self.GameData.CupSlots, 4, self.slotCup4)
		self:BindSlotButton(self.GameData.CupSlots, 5, self.slotCup5)

		self:BindSlotButton(self.GameData.IngredientSlots, 1, self.slotIng1)
		self:BindSlotButton(self.GameData.IngredientSlots, 2, self.slotIng2)

		self:BindSlotButton(self.GameData.Mixers, 1, self.slotMixer1)
		self:BindSlotButton(self.GameData.Mixers, 2, self.slotMixer2)
		self:BindSlotButton(self.GameData.Mixers, 3, self.slotMixer3)
	end

	method void BindSlotButton(any slots, number index, ButtonComponent button)
		if slots == nil or slots[index] == nil then
			return
		end

		slots[index].uiButton = button
	end

	method void ResetSlotViewsForDay()
		if self.GameData == nil then
			return
		end

		self:ResetSlotCollectionViews(self.GameData.CupSlots)
		self:ResetSlotCollectionViews(self.GameData.IngredientSlots)
		self:ResetSlotCollectionViews(self.GameData.Mixers)
	end

	method void ResetSlotCollectionViews(any slots)
		if slots == nil then
			return
		end

		for i = 1, #slots do
			self:ResetSlotView(slots[i])
		end
	end

	method void ResetSlotView(any slot)
		if slot == nil then
			return
		end

		if slot.uiButton ~= nil then
			slot.uiButton.Enable = true
		end
		self:SetSlotImage(slot, "")
		self:SetPrepSlotProgress(slot, 0)
	end

