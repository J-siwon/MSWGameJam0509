	method any CreateIngredientDefsFromDataSet()
		if _EntryService == nil or _DataService == nil then
			return nil
		end
		
		local dataSetId = _EntryService:GetDataSetIdByName(self.IngredientDataSetName)
		if dataSetId == nil or dataSetId == "" then
			return nil
		end
		
		local rowCount = _DataService:GetRowCount(self.IngredientDataSetName)
		if rowCount <= 0 then
			return nil
		end
		
		local ingredientDefs = {}
		for rowIndex = 1, rowCount do
			local ingredientId = self:Trim(_DataService:GetCell(self.IngredientDataSetName, rowIndex, "Id"))
			if ingredientId ~= "" then
				ingredientDefs[ingredientId] = {
					useCupSpace = self:ParseBoolean(_DataService:GetCell(self.IngredientDataSetName, rowIndex, "UseCupSpace"), true),
					displayName = self:Trim(_DataService:GetCell(self.IngredientDataSetName, rowIndex, "DisplayName")),
					canPrep = self:ParseBoolean(_DataService:GetCell(self.IngredientDataSetName, rowIndex, "CanPrep"), false),
					canMix = self:ParseBoolean(_DataService:GetCell(self.IngredientDataSetName, rowIndex, "CanMix"), true),
					canAddToCup = self:ParseBoolean(_DataService:GetCell(self.IngredientDataSetName, rowIndex, "CanAddToCup"), true),
					imageRUID = self:Trim(_DataService:GetCell(self.IngredientDataSetName, rowIndex, "ImageRUID")),
				}
			end
		end
		
		return ingredientDefs
	end

	method any CreateMixerRecipes()
		local recipes = self:CreateMixerRecipesFromDataSet()
		if recipes ~= nil then
			return recipes
		end
		
		log("MixerRecipeData dataset is not loaded. Use fallback mixer recipes.")
		return {
			["ColdWater|prepped_Ingredient_1"] = "Mixed_Cold_Ingredient_1",
			["HotWater|prepped_Ingredient_2"] = "Mixed_Hot_Ingredient_2",
			["ColdWater|prepped_Ingredient_3"] = "Mixed_Cold_Ingredient_3",
		}
	end

	method any CreateMixerRecipesFromDataSet()
		if _EntryService == nil or _DataService == nil then
			return nil
		end
		
		local dataSetId = _EntryService:GetDataSetIdByName(self.MixerRecipeDataSetName)
		if dataSetId == nil or dataSetId == "" then
			return nil
		end
		
		local rowCount = _DataService:GetRowCount(self.MixerRecipeDataSetName)
		if rowCount <= 0 then
			return nil
		end
		
		local recipes = {}
		for rowIndex = 1, rowCount do
			local ingredientsText = _DataService:GetCell(self.MixerRecipeDataSetName, rowIndex, "Ingredients")
			local resultIngredient = _DataService:GetCell(self.MixerRecipeDataSetName, rowIndex, "ResultIngredient")
			local recipeKey = self:CreateRecipeKeyFromText(ingredientsText)
			
			if recipeKey ~= "" and resultIngredient ~= nil and resultIngredient ~= "" then
				recipes[recipeKey] = self:Trim(resultIngredient)
			end
		end
		
		return recipes
	end

	method string CreateRecipeKeyFromText(string ingredientsText)
		if ingredientsText == nil or ingredientsText == "" then
			return ""
		end
		
		local ingredients = {}
		for ingredientId in string.gmatch(ingredientsText, "([^|]+)") do
			local trimmed = self:Trim(ingredientId)
			if trimmed ~= "" then
				table.insert(ingredients, trimmed)
			end
		end
		
		table.sort(ingredients)
		
		local key = ""
		for index, ingredientId in pairs(ingredients) do
			if key ~= "" then
				key = key .. "|"
			end
			key = key .. ingredientId
		end
		
		return key
	end

	method string Trim(string value)
		if value == nil then
			return ""
		end
		
		return string.gsub(value, "^%s*(.-)%s*$", "%1")
	end

	method boolean ParseBoolean(string value, boolean fallback)
		if value == nil or value == "" then
			return fallback
		end
		
		local normalized = string.lower(self:Trim(value))
		if normalized == "true" or normalized == "1" or normalized == "yes" or normalized == "y" then
			return true
		end
		if normalized == "false" or normalized == "0" or normalized == "no" or normalized == "n" then
			return false
		end
		
		return fallback
	end

	method any CreateMixers()
		return {
			[1] = self:CreateMixer("Mixer_1"),
			[2] = self:CreateMixer("Mixer_2"),
			[3] = self:CreateMixer("Mixer_3"),
		}
	end

	method any CreateSelectionManager()
		-- SelectionManagerFactory가 없을 때만 사용하는 예비 선택 매니저 생성 로직이다.
		local gameManager = self
		local manager = {
			state = "NONE",
			data = nil,
		}
		
		function manager:Clear()
			self.state = "NONE"
			self.data = nil
			gameManager:ClearSelectedButtonVisual()
			gameManager:HideActionUI()
		end
		
		function manager:Select(newState, newData, uiButton)
			self.state = newState
			self.data = newData
			gameManager:HideActionUI()
			
			if uiButton ~= nil then
				gameManager:ShowSelectedButtonVisual(uiButton)
			elseif newData ~= nil and newData.uiButton ~= nil then
				gameManager:ShowSelectedButtonVisual(newData.uiButton)
			else
				gameManager:ClearSelectedButtonVisual()
			end
			
			if newState == "INGREDIENT_SLOT" then
				if newData.state == "RAW" then
					if gameManager:CanPrepIngredient(newData.ingredientId) == true then
						gameManager:ShowPrepUI(newData)
					end
					gameManager:ShowDiscardUI(newData)
				elseif newData.state == "PREPPED" then
					gameManager:ShowDiscardUI(newData)
				end
			elseif newState == "PLACED_CUP" then
				gameManager:ShowDiscardUI(newData)
				if newData.isCoffeeMachine == true then
					gameManager:ShowBrewShotUI(newData)
				end
			elseif newState == "MIXER" then
				gameManager:ShowDiscardUI(newData)
				if newData.isMixed == false then
					gameManager:ShowMixUI(newData)
				end
			end
		end
		
		function manager:HandleClick(targetType, target)
			if targetType == "EMPTY" then
				self:Clear()
				return
			end
			
			if target ~= nil and self:IsSameSelection(targetType, target) == true then
				self:Clear()
				return
			end
			
			if targetType == "INGREDIENT_BTN" then
				self:Select("INGREDIENT", target.ingredientId, target.uiButton)
				return
			end
			
			if targetType == "CUP_TYPE_BTN" then
				self:Select("CUP_TYPE", target.cupType, target.uiButton)
				return
			end
			
			if targetType == "ICE_MAKER_BTN" then
				self:Select("ICE_MAKER", nil, target.uiButton)
				return
			end
			
			if targetType == "WATER_BTN" then
				self:Select("WATER", target.waterType, target.uiButton)
				return
			end
			
			local state = self.state
			
			if state == "NONE" then
				if targetType == "INGREDIENT_SLOT" and target.state ~= "EMPTY" then
					self:Select("INGREDIENT_SLOT", target)
				elseif targetType == "CUP_SLOT" and target.hasCup == true then
					self:Select("PLACED_CUP", target)
				elseif targetType == "MIXER" and target.isMixing ~= true and (#target.ingredients > 0 or target.isMixed == true) then
					self:Select("MIXER", target)
				end
				
			elseif state == "INGREDIENT" then
				if targetType == "CUP_SLOT" and target.hasCup == true then
					if gameManager:AddIngredientToCup(target.cupData, self.data) == true then
						self:Clear()
					end
				elseif targetType == "INGREDIENT_SLOT" and target.state == "EMPTY" then
					target.state = "RAW"
					target.ingredientId = self.data
					self:Clear()
				elseif targetType == "MIXER" and target.isMixed == false then
					if gameManager:AddIngredientToMixer(target, self.data) == true then
						self:Clear()
					end
				end
				
			elseif state == "CUP_TYPE" then
				if targetType == "CUP_SLOT" and target.hasCup == false then
					target.hasCup = true
					target.cupData = gameManager:CreateCup(self.data)
					gameManager:SetSlotImage(target, gameManager.cupImageRUID)
					self:Clear()
				end
				
			elseif state == "ICE_MAKER" then
				if targetType == "CUP_SLOT" and target.hasCup == true then
					if gameManager:AddIngredientToCup(target.cupData, "Ice") == true then
						self:Clear()
					end
				end
				
			elseif state == "WATER" then
				if targetType == "CUP_SLOT" and target.hasCup == true then
					if gameManager:AddIngredientToCup(target.cupData, self.data) == true then
						self:Clear()
					end
				elseif targetType == "MIXER" and target.isMixed == false then
					if gameManager:AddIngredientToMixer(target, self.data) == true then
						self:Clear()
					end
				end
				
			elseif state == "INGREDIENT_SLOT" then
				local slot = self.data
				local handled = false
				if slot.state == "PREPPED" then
					if targetType == "MIXER" and target.isMixed == false then
						if gameManager:AddIngredientToMixer(target, slot.ingredientId) == true then
							slot.state = "EMPTY"
							slot.ingredientId = nil
							gameManager:SetPrepSlotProgress(slot, 0)
							handled = true
							self:Clear()
						end
					elseif targetType == "CUP_SLOT" and target.hasCup == true then
						if gameManager:AddIngredientToCup(target.cupData, slot.ingredientId) == true then
							slot.state = "EMPTY"
							slot.ingredientId = nil
							gameManager:SetPrepSlotProgress(slot, 0)
							handled = true
							self:Clear()
						end
					end
				end
				
				if handled == false then
					self:Clear()
				end
				
			elseif state == "MIXER" then
				local mixer = self.data
				local handled = false
				if mixer.isMixed == true and mixer.isTrash == false then
					if targetType == "CUP_SLOT" and target.hasCup == true then
						if gameManager:AddIngredientToCup(target.cupData, mixer.resultId) == true then
							gameManager:ClearMixer(mixer)
							handled = true
							self:Clear()
						end
					end
				end
				
				if handled == false then
					self:Clear()
				end
				
			elseif state == "PLACED_CUP" then
				if targetType == "CUP_SLOT" then
					gameManager:MoveOrSwapCupSlot(self.data, target)
				end
				self:Clear()
			end
		end
		
		function manager:IsSameSelection(targetType, target)
			if self.state == "INGREDIENT" and targetType == "INGREDIENT_BTN" then
				return self.data == target.ingredientId
			end
			
			if self.state == "CUP_TYPE" and targetType == "CUP_TYPE_BTN" then
				return self.data == target.cupType
			end
			
			if self.state == "ICE_MAKER" and targetType == "ICE_MAKER_BTN" then
				return true
			end
			
			if self.state == "WATER" and targetType == "WATER_BTN" then
				return self.data == target.waterType
			end
			
			if self.state == "INGREDIENT_SLOT" and targetType == "INGREDIENT_SLOT" then
				return self.data == target
			end
			
			if self.state == "PLACED_CUP" and targetType == "CUP_SLOT" then
				return self.data == target
			end
			
			if self.state == "MIXER" and targetType == "MIXER" then
				return self.data == target
			end
			
			return false
		end
		
		function manager:HandleUIAction(action)
			if action == "PREP" and self.state == "INGREDIENT_SLOT" then
				local slot = self.data
				if slot.state == "RAW" and gameManager:CanPrepIngredient(slot.ingredientId) == true then
					gameManager:StartPrepIngredientSlot(slot)
					self:Clear()
				else
					log("Cannot prep ingredient: " .. tostring(slot.ingredientId))
				end
				
			elseif action == "BREW_SHOT" and self.state == "PLACED_CUP" then
				local slot = self.data
				if slot.isCoffeeMachine == true and slot.hasCup == true then
					gameManager:StartBrewShot(slot)
					self:Clear()
				end
				
			elseif action == "DISCARD" then
				if self.state == "INGREDIENT_SLOT" then
					local slot = self.data
					log("Discard ingredient slot: " .. slot.id .. " / ingredient: " .. tostring(slot.ingredientId))
					slot.state = "EMPTY"
					slot.ingredientId = nil
					gameManager:SetPrepSlotProgress(slot, 0)
				elseif self.state == "PLACED_CUP" then
					local slot = self.data
					log("Discard cup slot: " .. slot.id)
					slot.hasCup = false
					slot.cupData = nil
					gameManager:SetSlotImage(slot, "")
					gameManager:SetPrepSlotProgress(slot, 0)
				elseif self.state == "MIXER" then
					local mixer = self.data
					log("Discard mixer: " .. mixer.id)
					gameManager:ClearMixer(mixer)
				end
				self:Clear()
				
			elseif action == "MIX" and self.state == "MIXER" then
				local mixer = self.data
				if mixer.isMixed == false and mixer.isMixing ~= true and #mixer.ingredients > 0 then
					gameManager:StartMixMixer(mixer)
					self:Clear()
				end
			end
		end
		
		return manager
	end

	method string GetMixerResultId(any mixer)
		-- 믹서 관련 규칙은 MixerService에 위임하고, 서비스가 없으면 내부 fallback을 사용한다.
		if _MixerService ~= nil then
			return _MixerService:GetMixerResultId(self, mixer)
		end
		
		local recipeKey = self:GetMixerRecipeKey(mixer)
		local resultId = self.GameData.MixerRecipes[recipeKey]
		
		if resultId == nil then
			return "Trash"
		end
		
		return resultId
	end

	method boolean IsTrashMixerResult(any mixer)
		if _MixerService ~= nil then
			return _MixerService:IsTrashMixerResult(mixer)
		end
		
		return mixer.resultId == "Trash"
	end

	method any CreateMixer(string mixerId)
		if _MixerService ~= nil then
			return _MixerService:CreateMixer(mixerId)
		end
		
		return {
			id = mixerId,
			maxSpaceIngredientCount = 4,
			spaceIngredientCount = 0,
			ingredients = {},
			isMixing = false,
			isMixed = false,
			isTrash = false,
			resultId = nil,
		}
	end

	method boolean AddIngredientToMixer(any mixer, string ingredientId)
		if _MixerService ~= nil then
			return _MixerService:AddIngredientToMixer(self, mixer, ingredientId)
		end
		
		if mixer.isMixed == true or mixer.isMixing == true then
			log("Cannot add ingredient to mixer: " .. mixer.id)
			return false
		end
		
		if self:CanMixIngredient(ingredientId) == false then
			log("Ingredient cannot be added to mixer: " .. ingredientId)
			return false
		end
		
		local useMixerSpace = self:IsCupSpaceIngredient(ingredientId)
		
		if useMixerSpace == true and mixer.spaceIngredientCount >= mixer.maxSpaceIngredientCount then
			log("Mixer is full. Cannot add ingredient: " .. ingredientId)
			return false
		end
		
		table.insert(mixer.ingredients, ingredientId)
		
		if useMixerSpace == true then
			mixer.spaceIngredientCount = mixer.spaceIngredientCount + 1
		end
		
		log("Added ingredient to mixer: " .. mixer.id .. " / ingredient: " .. ingredientId)
		return true
	end

	method string GetMixerRecipeKey(any mixer)
		if _MixerService ~= nil then
			return _MixerService:GetMixerRecipeKey(mixer)
		end
		
		local ingredients = {}
		
		for index, ingredientId in pairs(mixer.ingredients) do
			table.insert(ingredients, ingredientId)
		end
		
		table.sort(ingredients)
		
		local key = ""
		for index, ingredientId in pairs(ingredients) do
			if key ~= "" then
				key = key .. "|"
			end
			key = key .. ingredientId
		end
		
		return key
	end

	method void ClearMixer(any mixer)
		if _MixerService ~= nil then
			_MixerService:ClearMixer(self, mixer)
			return
		end
		
		mixer.ingredients = {}
		mixer.spaceIngredientCount = 0
		mixer.isMixing = false
		mixer.isMixed = false
		mixer.isTrash = false
		mixer.resultId = nil
		self:SetPrepSlotProgress(mixer, 0)
	end

	method any CreateCup(string cupType)
		-- 컵 생성/재료 추가/정보 추출은 CupService에 위임하는 구조다.
		if _CupService ~= nil then
			return _CupService:CreateCup(cupType)
		end
		
		return {
			type = cupType,
			maxSpaceIngredientCount = 4,
			spaceIngredientCount = 0,
			ingredients = {},
		}
	end

	method boolean AddIngredientToCup(any cupData, string ingredientId)
		if _CupService ~= nil then
			return _CupService:AddIngredientToCup(self, cupData, ingredientId)
		end
		
		if self:CanAddIngredientToCup(ingredientId) == false then
			log("Ingredient cannot be added to cup: " .. ingredientId)
			return false
		end
		
		local useCupSpace = self:IsCupSpaceIngredient(ingredientId)
		
		if useCupSpace == true and cupData.spaceIngredientCount >= cupData.maxSpaceIngredientCount then
			log("Cup is full. Cannot add ingredient: " .. ingredientId)
			return false
		end
		
		table.insert(cupData.ingredients, ingredientId)
		
		if useCupSpace == true then
			cupData.spaceIngredientCount = cupData.spaceIngredientCount + 1
		end
		
		log("Added ingredient to cup: " .. ingredientId)
		return true
	end

	method any GetIngredientDef(string ingredientId)
		-- 재료 규칙은 IngredientDefs 테이블 하나를 기준으로 조회한다.
		if self.GameData == nil or self.GameData.IngredientDefs == nil then
			return nil
		end
		
		return self.GameData.IngredientDefs[ingredientId]
	end

	method boolean CanAddIngredientToCup(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canAddToCup ~= nil then
			return ingredientDef.canAddToCup
		end
		
		return true
	end

	method boolean CanMixIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canMix ~= nil then
			return ingredientDef.canMix
		end
		
		return true
	end

	method boolean CanPrepIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		if ingredientDef ~= nil and ingredientDef.canPrep ~= nil then
			return ingredientDef.canPrep
		end
		
		return false
	end

	method boolean IsCupSpaceIngredient(string ingredientId)
		local ingredientDef = self:GetIngredientDef(ingredientId)
		
		if ingredientDef ~= nil and ingredientDef.useCupSpace ~= nil then
			return ingredientDef.useCupSpace
		end
		
		return true
	end

	method any GetCupInfoFromSlot(any slot)
		-- 다른 팀원이 메뉴 큐에서 사용할 수 있도록 컵 정보를 안전한 테이블로 변환한다.
		if _CupService ~= nil then
			return _CupService:GetCupInfoFromSlot(slot)
		end
		
		if slot == nil or slot.hasCup ~= true or slot.cupData == nil then
			return nil
		end
		
		return self:GetCupInfo(slot.cupData)
	end

	method any GetCupInfo(any cupData)
		if _CupService ~= nil then
			return _CupService:GetCupInfo(cupData)
		end
		
		if cupData == nil then
			return nil
		end
		
		local ingredients = {}
		local ingredientCounts = {}
		
		for index = 1, #cupData.ingredients do
			local ingredientId = cupData.ingredients[index]
			table.insert(ingredients, ingredientId)
			
			if ingredientCounts[ingredientId] == nil then
				ingredientCounts[ingredientId] = 0
			end
			ingredientCounts[ingredientId] = ingredientCounts[ingredientId] + 1
		end
		
		return {
			cupType = cupData.type,
			ingredients = ingredients,
			ingredientCounts = ingredientCounts,
			spaceIngredientCount = cupData.spaceIngredientCount,
			maxSpaceIngredientCount = cupData.maxSpaceIngredientCount,
		}
	end

	method string GetCupInfoText(any cupInfo)
		if _CupService ~= nil then
			return _CupService:GetCupInfoText(cupInfo)
		end
		
		if cupInfo == nil then
			return "empty"
		end
		
		return "cupType: " .. tostring(cupInfo.cupType)
			.. " / ingredients: " .. self:GetIngredientListText(cupInfo)
			.. " / space: " .. tostring(cupInfo.spaceIngredientCount)
			.. "/" .. tostring(cupInfo.maxSpaceIngredientCount)
	end

	method void LogCupSlotInfo(any slot)
		if slot == nil then
			return
		end
		
		local cupInfo = self:GetCupInfoFromSlot(slot)
		if cupInfo == nil then
			log("Clicked cup slot: " .. slot.id .. " / hasCup: false")
			return
		end
		
		log("Clicked cup slot: " .. slot.id .. " / hasCup: true / " .. self:GetCupInfoText(cupInfo))
	end

	method void ShowPrepUI(any target)
		-- 선택된 대상에 따라 공용 액션 버튼을 노출한다.
		self.prepTargetSlot = target
		self:ShowPrepButton()
	end

	method void ShowBrewShotUI(any target)
		self.brewShotTargetSlot = target
		self:ShowBrewShotButton()
	end

	method void ShowDiscardUI(any target)
		self:ShowDiscardButton()
	end

	method void ShowMixUI(any target)
		self.mixTargetMixer = target
		self:ShowMixButton()
	end

	method void HideActionUI()
		self:HidePrepButton()
		self:HideBrewShotButton()
		self:HideMixButton()
		self:HideDiscardButton()
	end

	method any CreateActionButtonConfigs()
		-- 액션 버튼별 위치와 이동 방향을 테이블로 관리해 중복 tween 코드를 줄인다.
		return {
			Prep = { button = self.btnPrepAction, axis = "X", showX = self.prepButtonShowX, hideX = self.prepButtonHideX, fixedY = self.prepButtonY },
			BrewShot = { button = self.btnBrewShotAction, axis = "X", showX = self.prepButtonShowX, hideX = self.prepButtonHideX, fixedY = self.brewShotButtonY },
			Mix = { button = self.btnMixAction, axis = "X", showX = self.prepButtonShowX, hideX = self.prepButtonHideX, fixedY = self.mixButtonY },
			Discard = { button = self.btnDiscardAction, axis = "Y", showY = self.discardButtonShowY, hideY = self.discardButtonHideY, fixedX = self.discardButtonX },
		}
	end

	method void ShowPrepButton()
		self:ShowActionButton("Prep")
	end

	method void HidePrepButton()
		self:HideActionButton("Prep")
	end

	method void HidePrepButtonImmediately()
		self:HideActionButtonImmediately("Prep")
	end

	method void ShowBrewShotButton()
		self:ShowActionButton("BrewShot")
	end

	method void HideBrewShotButton()
		self:HideActionButton("BrewShot")
	end

	method void HideBrewShotButtonImmediately()
		self:HideActionButtonImmediately("BrewShot")
	end

	method void ShowMixButton()
		self:ShowActionButton("Mix")
	end

	method void HideMixButton()
		self:HideActionButton("Mix")
	end

	method void HideMixButtonImmediately()
		self:HideActionButtonImmediately("Mix")
	end

	method void ShowDiscardButton()
		self:ShowActionButton("Discard")
	end

	method void HideDiscardButton()
		self:HideActionButton("Discard")
	end

	method void HideDiscardButtonImmediately()
		self:HideActionButtonImmediately("Discard")
	end

	method void HideActionButtonsImmediately()
		self:HideActionButtonImmediately("Prep")
		self:HideActionButtonImmediately("BrewShot")
		self:HideActionButtonImmediately("Mix")
		self:HideActionButtonImmediately("Discard")
	end

	method void ShowActionButton(string actionKey)
		-- 액션 버튼은 먼저 활성화한 뒤 설정된 방향으로 튀어나오게 한다.
		local config = self:GetActionButtonConfig(actionKey)
		if config == nil then
			return
		end
		
		config.button.Entity.Enable = true
		config.button.Enable = true
		self:StartActionButtonTween(actionKey, true)
	end

	method void HideActionButton(string actionKey)
		local config = self:GetActionButtonConfig(actionKey)
		if config == nil then
			return
		end
		
		config.button.Enable = false
		self:StartActionButtonTween(actionKey, false)
	end

	method void HideActionButtonImmediately(string actionKey)
		-- 게임 시작 시에는 tween 없이 숨겨진 위치로 바로 보낸다.
		local config = self:GetActionButtonConfig(actionKey)
		if config == nil then
			return
		end
		
		self:ClearActionButtonTween(actionKey)
		
		local transform = config.button.Entity.UITransformComponent
		local x = config.fixedX
		local y = config.fixedY
		if config.axis == "X" then
			x = config.hideX
		else
			y = config.hideY
		end
		
		self:SetUIPosition(transform, x, y)
		config.button.Enable = false
		config.button.Entity.Enable = false
	end

	method any GetActionButtonConfig(string actionKey)
		if self.actionButtonConfigs == nil then
			return nil
		end
		
		return self.actionButtonConfigs[actionKey]
	end

	method void ClearActionButtonTween(string actionKey)
		if self.actionButtonTweenIds == nil then
			self.actionButtonTweenIds = {}
		end
		
		local tweenId = self.actionButtonTweenIds[actionKey]
		if tweenId ~= nil and tweenId ~= 0 then
			_TimerService:ClearTimer(tweenId)
		end
		
		self.actionButtonTweenIds[actionKey] = 0
	end

	method void StartActionButtonTween(string actionKey, boolean show)
		-- 손질/샷/믹싱/버리기 버튼의 등장과 퇴장을 하나의 tween 로직으로 처리한다.
		local config = self:GetActionButtonConfig(actionKey)
		if config == nil then
			return
		end
		
		self:ClearActionButtonTween(actionKey)
		
		local transform = config.button.Entity.UITransformComponent
		local fromValue = transform.anchoredPosition.x
		local toValue = config.hideX
		if config.axis == "Y" then
			fromValue = transform.anchoredPosition.y
			toValue = config.hideY
		end
		if show == true then
			if config.axis == "X" then
				toValue = config.showX
			else
				toValue = config.showY
			end
		end
		
		local time = 0
		local preTime = _UtilLogic.ElapsedSeconds
		local gameManager = self
		
		local tween = function()
			local delta = _UtilLogic.ElapsedSeconds - preTime
			preTime = _UtilLogic.ElapsedSeconds
			time = time + delta
			
			local t = math.min(time / gameManager.prepButtonTweenDuration, 1)
			local value = fromValue + (toValue - fromValue) * t
			if config.axis == "X" then
				gameManager:SetUIPosition(transform, value, config.fixedY)
			else
				gameManager:SetUIPosition(transform, config.fixedX, value)
			end
			
			if t >= 1 then
				gameManager:ClearActionButtonTween(actionKey)
				if show == false then
					config.button.Entity.Enable = false
				end
			end
		end
		
		self.actionButtonTweenIds[actionKey] = _TimerService:SetTimerRepeat(tween, 1 / 60)
	end

	method void SetUIPosition(any transform, number x, number y)
		local width = transform.RectSize.x
		local height = transform.RectSize.y
		transform.anchoredPosition = Vector2(x, y)
		transform.Position = Vector3(x, y, 0)
		transform.OffsetMin = Vector2(x - width / 2, y - height / 2)
		transform.OffsetMax = Vector2(x + width / 2, y + height / 2)
	end

	method void StartPrepIngredientSlot(any slot)
		-- 재료 손질은 슬롯 하나를 잠그고 진행바를 채운 뒤 완료 시 손질 재료로 바꾼다.
		if slot == nil or slot.uiButton == nil then
			return
		end
		
		if self:CanPrepIngredient(slot.ingredientId) == false then
			log("Cannot start prep ingredient slot: " .. slot.id .. " / ingredient: " .. tostring(slot.ingredientId))
			return
		end
		
		log("Start prepping ingredient slot: " .. slot.id)
		slot.state = "PREPPING"
		self.prepTargetSlot = nil
		slot.uiButton.Enable = false
		self:SetPrepSlotProgress(slot, 0)
		local gameManager = self
		self:StartProgressTimer("Prep", slot, self.prepDuration, function(target) gameManager:FinishPrepIngredientSlot(target) end)
	end

	method void FinishPrepIngredientSlot(any slot)
		slot.state = "PREPPED"
		slot.ingredientId = self:GetPreppedIngredientId(slot.ingredientId)
		slot.uiButton.Enable = true
		self:SetPrepSlotProgress(slot, 0)
		log("Finished prepping ingredient slot: " .. slot.id .. " / ingredient: " .. slot.ingredientId)
	end

	method void StartBrewShot(any slot)
		-- 샷 내리는 중에는 해당 컵 슬롯을 비활성화해서 이동/스왑을 막는다.
		if slot == nil or slot.uiButton == nil or slot.cupData == nil then
			return
		end
		
		log("Start brewing shot: " .. slot.id .. " / shot: " .. slot.coffeeShotId)
		self.brewShotTargetSlot = nil
		slot.isBrewingShot = true
		slot.uiButton.Enable = false
		self:SetPrepSlotProgress(slot, 0)
		local gameManager = self
		self:StartProgressTimer("BrewShot", slot, self.brewShotDuration, function(target) gameManager:FinishBrewShot(target) end)
	end

	method void FinishBrewShot(any slot)
		slot.isBrewingShot = false
		slot.uiButton.Enable = true
		self:SetPrepSlotProgress(slot, 0)
		self:AddIngredientToCup(slot.cupData, slot.coffeeShotId)
		log("Finished brewing shot: " .. slot.id .. " / shot: " .. slot.coffeeShotId)
	end

	method void StartMixMixer(any mixer)
		-- 믹싱 중에는 해당 믹서컵만 비활성화하고 완료 시 결과 재료만 남긴다.
		if mixer == nil or mixer.uiButton == nil then
			return
		end
		
		log("Start mixing: " .. mixer.id .. " / ingredients: " .. self:GetIngredientListText(mixer))
		mixer.isMixing = true
		self.mixTargetMixer = nil
		mixer.uiButton.Enable = false
		self:SetPrepSlotProgress(mixer, 0)
		local gameManager = self
		self:StartProgressTimer("Mix", mixer, self.mixDuration, function(target) gameManager:FinishMixMixer(target) end)
	end

	method void FinishMixMixer(any mixer)
		local resultId = self:GetMixerResultId(mixer)
		
		mixer.ingredients = {}
		mixer.spaceIngredientCount = 0
		mixer.isMixing = false
		mixer.isMixed = true
		mixer.resultId = resultId
		mixer.isTrash = self:IsTrashMixerResult(mixer)
		mixer.uiButton.Enable = true
		self:SetPrepSlotProgress(mixer, 0)
		
		log("Finished mixing: " .. mixer.id .. " / result: " .. resultId)
	end

	method string GetPreppedIngredientId(string ingredientId)
		if string.sub(ingredientId, 1, 8) == "prepped_" then
			return ingredientId
		end
		
		return "prepped_" .. ingredientId
	end

	method void StartProgressTimer(string timerKey, any target, number duration, any onFinished)
		-- 손질/샷/믹싱의 진행바와 1초 타이머를 공통으로 처리한다.
		self:ClearProgressTimer(timerKey)
		
		local time = 0
		local preTime = _UtilLogic.ElapsedSeconds
		local gameManager = self
		
		local tick = function()
			local delta = _UtilLogic.ElapsedSeconds - preTime
			preTime = _UtilLogic.ElapsedSeconds
			time = time + delta
			
			local progress = math.min(time / duration, 1)
			gameManager:SetPrepSlotProgress(target, progress)
			
			if progress >= 1 then
				gameManager:ClearProgressTimer(timerKey)
				onFinished(target)
			end
		end
		
		if self.progressTimerIds == nil then
			self.progressTimerIds = {}
		end
		self.progressTimerIds[timerKey] = _TimerService:SetTimerRepeat(tick, 1 / 60)
	end

	method void ClearProgressTimer(string timerKey)
		if self.progressTimerIds == nil then
			self.progressTimerIds = {}
		end
		
		local timerId = self.progressTimerIds[timerKey]
		if timerId ~= nil and timerId ~= 0 then
			_TimerService:ClearTimer(timerId)
		end
		
		self.progressTimerIds[timerKey] = 0
	end

	method void SetPrepSlotProgress(any slot, number progress)
		if slot == nil or slot.uiButton == nil then
			return
		end
		
		local sprite = slot.uiButton.Entity.SpriteGUIRendererComponent
		sprite.FillAmount = progress
	end

	method void SetSlotImage(any slot, string imageRUID)
		-- 슬롯의 기본 스프라이트를 교체한다. UI 이미지가 확정되면 이 경로를 주로 사용한다.
		if slot == nil or slot.uiButton == nil then
			return
		end
		
		slot.uiButton.Entity.SpriteGUIRendererComponent.ImageRUID.DataId = imageRUID
	end

	method void RefreshCupSlotImage(any slot)
		if slot == nil then
			return
		end
		
		if slot.hasCup == true then
			self:SetSlotImage(slot, self.cupImageRUID)
		else
			self:SetSlotImage(slot, "")
		end
	end

	method void MoveOrSwapCupSlot(any fromSlot, any toSlot)
		-- 컵이 있는 슬롯을 선택한 상태에서 다른 컵 슬롯을 누르면 이동 또는 스왑한다.
		if fromSlot == nil or toSlot == nil then
			return
		end
		
		if fromSlot == toSlot then
			return
		end
		
		if fromSlot.isBrewingShot == true or toSlot.isBrewingShot == true then
			log("Cannot move or swap cup while brewing shot")
			return
		end
		
		if fromSlot.hasCup ~= true then
			return
		end
		
		local fromCupData = fromSlot.cupData
		local toCupData = toSlot.cupData
		local toHasCup = toSlot.hasCup
		
		toSlot.hasCup = true
		toSlot.cupData = fromCupData
		
		fromSlot.hasCup = toHasCup
		fromSlot.cupData = toCupData
		
		self:RefreshCupSlotImage(fromSlot)
		self:RefreshCupSlotImage(toSlot)
		
		if toHasCup == true then
			log("Swapped cups: " .. fromSlot.id .. " <-> " .. toSlot.id)
		else
			log("Moved cup: " .. fromSlot.id .. " -> " .. toSlot.id)
		end
	end

	method void ShowSelectedButtonVisual(ButtonComponent button)
		-- 현재 선택된 버튼은 노란 외곽선으로 표시한다.
		self:ClearSelectedButtonVisual()
		
		log("Showing selected button visual for button: " .. button.Entity.Name)
		self.selectedButtonEntity = button.Entity
		local sprite = button.Entity.SpriteGUIRendererComponent
		sprite.Outline = true
		sprite.OutlineWidth = 10
		sprite.OutlineColor = Color(1, 0.9, 0, 1)
	end

	method void ClearSelectedButtonVisual()
		-- 이전 선택 표시를 기본 외곽선으로 되돌린다.
		if self.selectedButtonEntity == nil then
			return
		end
		log("Clearing selected button visual")
		local sprite = self.selectedButtonEntity.SpriteGUIRendererComponent
		sprite.Outline = true
		sprite.OutlineWidth = 3
		sprite.OutlineColor = Color(0, 0, 0, 1)
		self.selectedButtonEntity = nil
	end

	method void ConnectGameButtons()
		-- UI 버튼과 게임 로직의 클릭 핸들러를 한 번에 연결한다.
		log("Connect game buttons")
		
		self.btnIceCup.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupTypeButton("IceCup", self.btnIceCup) end)
		self.btnHotCup.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupTypeButton("HotCup", self.btnHotCup) end)
		self.btnIceMaker.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIceMakerButton(self.btnIceMaker) end)
		self.btnColdWater.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickWaterButton("ColdWater", self.btnColdWater) end)
		self.btnHotWater.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickWaterButton("HotWater", self.btnHotWater) end)
		
		self.btnIng1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_1", self.btnIng1) end)
		self.btnIng2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_2", self.btnIng2) end)
		self.btnIng3.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_3", self.btnIng3) end)
		self.btnIng4.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_4", self.btnIng4) end)
		self.btnIng5.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_5", self.btnIng5) end)
		self.btnIng6.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_6", self.btnIng6) end)
		self.btnIng7.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_7", self.btnIng7) end)
		self.btnIng8.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientButton("Ingredient_8", self.btnIng8) end)
		
		self.slotCup1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[1], self.slotCup1) end)
		self.slotCup2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[2], self.slotCup2) end)
		self.slotCup3.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[3], self.slotCup3) end)
		self.slotCup4.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[4], self.slotCup4) end)
		self.slotCup5.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickCupSlot(self.GameData.CupSlots[5], self.slotCup5) end)
		
		self.slotIng1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientSlot(self.GameData.IngredientSlots[1], self.slotIng1) end)
		self.slotIng2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickIngredientSlot(self.GameData.IngredientSlots[2], self.slotIng2) end)
		
		self.slotMixer1.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickMixer(self.GameData.Mixers[1], self.slotMixer1) end)
		self.slotMixer2.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickMixer(self.GameData.Mixers[2], self.slotMixer2) end)
		self.slotMixer3.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickMixer(self.GameData.Mixers[3], self.slotMixer3) end)
		self.btnPrepAction.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickPrepAction() end)
		self.btnBrewShotAction.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickBrewShotAction() end)
		self.btnMixAction.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickMixAction() end)
		self.btnDiscardAction.Entity:ConnectEvent(ButtonClickEvent, function() self:OnClickDiscardAction() end)
		
		log("Game buttons connected")
	end

	method void OnClickIngredientButton(string ingredientId, ButtonComponent sourceButton)
		-- 아래쪽 고정 버튼들은 선택 상태만 바꾸고, 실제 상호작용은 SelectionManager가 판단한다.
		log("Clicked ingredient button: " .. ingredientId)
		self.SelectionManager:HandleClick("INGREDIENT_BTN", { ingredientId = ingredientId, uiButton = sourceButton })
	end

	method void OnClickCupTypeButton(string cupType, ButtonComponent sourceButton)
		log("Clicked cup type button: " .. cupType)
		self.SelectionManager:HandleClick("CUP_TYPE_BTN", { cupType = cupType, uiButton = sourceButton })
	end

	method void OnClickIceMakerButton(ButtonComponent sourceButton)
		log("Clicked ice maker button")
		self.SelectionManager:HandleClick("ICE_MAKER_BTN", { uiButton = sourceButton })
	end

	method void OnClickWaterButton(string waterType, ButtonComponent sourceButton)
		log("Clicked water button: " .. waterType)
		self.SelectionManager:HandleClick("WATER_BTN", { waterType = waterType, uiButton = sourceButton })
	end

	method void OnClickIngredientSlot(any slot, ButtonComponent sourceButton)
		log("Clicked ingredient slot: " .. slot.id)
		slot.uiButton = sourceButton
		self.SelectionManager:HandleClick("INGREDIENT_SLOT", slot)
	end

	method void OnClickCupSlot(any slot, ButtonComponent sourceButton)
		self:LogCupSlotInfo(slot)
		slot.uiButton = sourceButton
		self.SelectionManager:HandleClick("CUP_SLOT", slot)
	end

	method string GetIngredientListText(any cupData)
		if cupData == nil or cupData.ingredients == nil or #cupData.ingredients == 0 then
			return "empty"
		end
		
		local text = ""
		for index, ingredientId in pairs(cupData.ingredients) do
			if text ~= "" then
				text = text .. ", "
			end
			text = text .. ingredientId
		end
		
		return text
	end

	method void OnClickMixer(any mixer, ButtonComponent sourceButton)
		log("Clicked mixer: " .. mixer.id)
		mixer.uiButton = sourceButton
		self.SelectionManager:HandleClick("MIXER", mixer)
	end

	method void OnClickEmptySpace()
		log("Clicked empty space")
		self.SelectionManager:HandleClick("EMPTY", {})
	end

	method void OnClickUIAction(string action)
		log("Clicked UI action: " .. action)
		self.SelectionManager:HandleUIAction(action)
	end

	method void OnClickPrepAction()
		log("Clicked prep action")
		self.SelectionManager:HandleUIAction("PREP")
	end

	method void OnClickBrewShotAction()
		log("Clicked brew shot action")
		self.SelectionManager:HandleUIAction("BREW_SHOT")
	end

	method void OnClickMixAction()
		log("Clicked mix action")
		self.SelectionManager:HandleUIAction("MIX")
	end

	method void OnClickDiscardAction()
		log("Clicked discard action")
		self.SelectionManager:HandleUIAction("DISCARD")
	end

end
