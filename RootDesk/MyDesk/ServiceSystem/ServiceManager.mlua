	method void StartProgressTimer(string timerKey, any target, number duration, any onFinished)
		-- 손질/샷/믹싱의 진행바와 1초 타이머를 공통으로 처리한다.
		-- TODO: timerKey가 작업 종류 단위라 같은 종류의 동시 작업이 서로 취소될 수 있다. 동작 변경 패스에서 target id 기준으로 분리한다.
		if _WorkProcessService ~= nil then
			_WorkProcessService:StartProgressTimer(self, timerKey, target, duration, onFinished)
